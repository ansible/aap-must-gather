            background-color: #f39c12;
            color: #000;
            border-radius: 2px;
            font-weight: bold;
        }
        .search-info {
            color: #d4d4d4;
            font-size: 14px;
            margin-left: 10px;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>📄 FILE_TITLE</h1>
        <div class="file-info">AAP Must-Gather Output</div>
    </div>
    <div class="controls">
        <button class="btn" onclick="window.history.back()">← Back</button>
        <button class="btn" onclick="downloadFile()">⬇ Download</button>
        <button class="btn" onclick="toggleLineNumbers()">🔢 Toggle Line Numbers</button>
        <input type="text" class="search-box" id="search-input" placeholder="Search in file... (Press Enter to cycle)" onkeyup="handleSearch(event)">
        <span class="search-info" id="search-info"></span>
    </div>
    <div class="content">
        <pre id="file-content" class="SYNTAX_CLASS">
EOF_HTML_HEADER

  # Replace placeholders
  sed -i "s/FILE_TITLE/$title/g" "$output_file"
  sed -i "s/SYNTAX_CLASS/$syntax_class/g" "$output_file"

  # Escape HTML entities and add content
  if [ -f "$input_file" ]; then
    sed 's/&/\&amp;/g; s/</\&lt;/g; s/>/\&gt;/g; s/"/\&quot;/g; s/'\''/\&#39;/g' "$input_file" >> "$output_file"
  else
    echo "File not found: $input_file" >> "$output_file"
  fi

  # Add closing HTML
  cat >> "$output_file" << 'EOF_HTML_FOOTER'
</pre>
    </div>
    <script>
        let lineNumbersEnabled = false;
        let searchMatches = [];
        let currentMatchIndex = -1;
        let originalContent = '';

        function toggleLineNumbers() {
            const content = document.getElementById('file-content');
            lineNumbersEnabled = !lineNumbersEnabled;

            if (lineNumbersEnabled) {
                const lines = content.textContent.split('\n');
                content.innerHTML = lines.map(line =>
                    '<span class="line">' + escapeHtml(line) + '</span>'
                ).join('\n');
                content.classList.add('line-numbers');
            } else {
                const text = content.textContent;
                content.textContent = text;
                content.classList.remove('line-numbers');
            }

            // Reapply search highlighting if there's an active search
            const searchInput = document.getElementById('search-input');
            if (searchInput && searchInput.value) {
                performSearch(searchInput.value, false);
            }
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function downloadFile() {
            const filename = 'FILE_TITLE'.replace('.html', '');
            const content = document.getElementById('file-content').textContent;
            const blob = new Blob([content], { type: 'text/plain' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            window.URL.revokeObjectURL(url);
        }

        function handleSearch(event) {
            const query = event.target.value;

            if (event.key === 'Enter') {
                // Cycle to next match
                if (searchMatches.length > 0) {
                    cycleToNextMatch();
                }
            } else {
                // Perform new search
                performSearch(query, true);
            }
        }

        function performSearch(query, resetIndex) {
            const content = document.getElementById('file-content');
            const searchInfo = document.getElementById('search-info');

            if (!originalContent) {
                originalContent = content.textContent;
            }

            if (!query) {
                content.textContent = originalContent;
                searchMatches = [];
                currentMatchIndex = -1;
                searchInfo.textContent = '';

                // Reapply line numbers if enabled
                if (lineNumbersEnabled) {
                    const lines = content.textContent.split('\n');
                    content.innerHTML = lines.map(line =>
                        '<span class="line">' + escapeHtml(line) + '</span>'
                    ).join('\n');
                    content.classList.add('line-numbers');
                }
                return;
            }

            const text = originalContent;
            const regex = new RegExp(query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'gi');

            // Find all matches
            searchMatches = [];
            let match;
            while ((match = regex.exec(text)) !== null) {
                searchMatches.push({
                    index: match.index,
                    length: match[0].length,
                    text: match[0]
                });
            }

            if (resetIndex) {
                currentMatchIndex = searchMatches.length > 0 ? 0 : -1;
            }

            // Highlight all matches
            highlightMatches(text, query);

            // Update search info
            if (searchMatches.length > 0) {
                searchInfo.textContent = `Match ${currentMatchIndex + 1} of ${searchMatches.length}`;
            } else {
                searchInfo.textContent = 'No matches found';
            }
        }

        function highlightMatches(text, query) {
            const content = document.getElementById('file-content');
            const regex = new RegExp(query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'gi');

            let lastIndex = 0;
            let highlighted = '';
            let matchCount = 0;

            let match;
            regex.lastIndex = 0;
            while ((match = regex.exec(text)) !== null) {
                // Add text before match
                highlighted += escapeHtml(text.substring(lastIndex, match.index));

                // Add highlighted match
                const className = matchCount === currentMatchIndex ? 'highlight-current' : 'highlight-match';
                highlighted += '<span class="' + className + '">' + escapeHtml(match[0]) + '</span>';

                lastIndex = match.index + match[0].length;
                matchCount++;
            }

            // Add remaining text
            highlighted += escapeHtml(text.substring(lastIndex));

            content.innerHTML = highlighted;

            // Reapply line numbers if enabled
            if (lineNumbersEnabled) {
                const lines = content.innerHTML.split('\n');
                content.innerHTML = lines.map(line =>
                    '<span class="line">' + line + '</span>'
                ).join('\n');
                content.classList.add('line-numbers');
            }

            // Scroll to current match
            if (currentMatchIndex >= 0) {
                scrollToCurrentMatch();
            }
        }

        function cycleToNextMatch() {
            if (searchMatches.length === 0) return;

            currentMatchIndex = (currentMatchIndex + 1) % searchMatches.length;

            const searchInput = document.getElementById('search-input');
            const searchInfo = document.getElementById('search-info');

            // Re-highlight with new current match
            highlightMatches(originalContent, searchInput.value);

            // Update search info
            searchInfo.textContent = `Match ${currentMatchIndex + 1} of ${searchMatches.length}`;
        }

        function scrollToCurrentMatch() {
            const currentMatch = document.querySelector('.highlight-current');
            if (currentMatch) {
                currentMatch.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }
    </script>
</body>
</html>
EOF_HTML_FOOTER

  # Fix the download filename in the JavaScript
  sed -i "s/FILE_TITLE/$title/g" "$output_file"
}

# Function to collect initContainer logs
collect_init_container_logs() {
  local namespace=$1
  echo "Collecting initContainer logs for namespace: $namespace"

  # Get all pods in the namespace
  for pod in $(oc get pods -n $namespace -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    # Check if pod has initContainers
    init_containers=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.initContainers[*].name}' 2>/dev/null)
    if [ ! -z "$init_containers" ]; then
      echo "Found initContainers in pod $pod: $init_containers"
      for init_container in $init_containers; do
        echo "Collecting logs for initContainer: $init_container in pod: $pod"
        oc logs $pod -n $namespace -c $init_container > "${BASE_COLLECTION_PATH}/logs/${pod}-${init_container}-init.log" 2>/dev/null || echo "Failed to collect logs for initContainer $init_container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      done
    fi
  done
}

# Function to collect migration job logs
collect_migration_job_logs() {
  local namespace=$1
  echo "Collecting migration job logs for namespace: $namespace"

  # Collect logs from controller migration jobs
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=automationcontroller --field-selector=status.phase=Succeeded -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    # Check if this is a migration job pod
    if [[ "$pod" == *"migration"* ]]; then
      echo "Found controller migration job pod: $pod"
      # Get the container name for the migration job
      migration_container=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[0].name}' 2>/dev/null)
      if [ ! -z "$migration_container" ]; then
        echo "Collecting logs for migration job container: $migration_container in pod: $pod"
        oc logs $pod -n $namespace -c $migration_container > "${BASE_COLLECTION_PATH}/logs/${pod}-${migration_container}.log" 2>/dev/null || echo "Failed to collect logs for migration job $migration_container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      fi
    fi
  done

  # Also collect logs from any running or failed migration jobs
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=automationcontroller --field-selector=status.phase=Failed -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    if [[ "$pod" == *"migration"* ]]; then
      echo "Found failed controller migration job pod: $pod"
      migration_container=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[0].name}' 2>/dev/null)
      if [ ! -z "$migration_container" ]; then
        echo "Collecting logs for failed migration job container: $migration_container in pod: $pod"
        oc logs $pod -n $namespace -c $migration_container > "${BASE_COLLECTION_PATH}/logs/${pod}-${migration_container}.log" 2>/dev/null || echo "Failed to collect logs for failed migration job $migration_container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      fi
    fi
  done

  # Collect logs from gateway migration jobs
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/name=automation-platform-gateway --field-selector=status.phase=Succeeded -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    if [[ "$pod" == *"migration"* ]]; then
      echo "Found gateway migration job pod: $pod"
      migration_container=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[0].name}' 2>/dev/null)
      if [ ! -z "$migration_container" ]; then
        echo "Collecting logs for gateway migration job container: $migration_container in pod: $pod"
        oc logs $pod -n $namespace -c $migration_container > "${BASE_COLLECTION_PATH}/logs/${pod}-${migration_container}.log" 2>/dev/null || echo "Failed to collect logs for gateway migration job $migration_container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      fi
    fi
  done

  # Collect logs from EDA migration jobs
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=eda --field-selector=status.phase=Succeeded -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    if [[ "$pod" == *"migration"* ]]; then
      echo "Found EDA migration job pod: $pod"
      migration_container=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[0].name}' 2>/dev/null)
      if [ ! -z "$migration_container" ]; then
        echo "Collecting logs for EDA migration job container: $migration_container in pod: $pod"
        oc logs $pod -n $namespace -c $migration_container > "${BASE_COLLECTION_PATH}/logs/${pod}-${migration_container}.log" 2>/dev/null || echo "Failed to collect logs for EDA migration job $migration_container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      fi
    fi
  done
}

# Function to collect operator pod logs
collect_operator_logs() {
  local namespace=$1
  echo "Collecting operator pod logs for namespace: $namespace"

  # Collect logs from AAP operator pods
  for pod in $(oc get pods -n $namespace -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    # Check if this is an operator pod
    if [[ "$pod" == *"operator-controller-manager"* ]]; then
      echo "Found operator pod: $pod"

      # Get all containers in the operator pod
      containers=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[*].name}' 2>/dev/null)
      if [ ! -z "$containers" ]; then
        for container in $containers; do
          echo "Collecting logs for operator container: $container in pod: $pod"
          oc logs $pod -n $namespace -c $container > "${BASE_COLLECTION_PATH}/logs/${pod}-${container}-operator.log" 2>/dev/null || echo "Failed to collect logs for operator container $container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
        done
      fi

      # Also collect previous logs if available (useful for crashed operators)
      for container in $containers; do
        echo "Collecting previous logs for operator container: $container in pod: $pod"
        oc logs $pod -n $namespace -c $container --previous > "${BASE_COLLECTION_PATH}/logs/${pod}-${container}-operator-previous.log" 2>/dev/null || echo "No previous logs available for operator container $container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      done
    fi
  done
}

# Function to collect configuration files from key containers
collect_config_files() {
  local namespace=$1
  echo "Collecting configuration files from key containers for namespace: $namespace"

  # Create config directory
  mkdir -p "${BASE_COLLECTION_PATH}/configs"

  # Gateway-api pods - collect proxy.yml, nginx.conf, redis.conf
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=aap-gateway -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting config files from gateway pod: $pod"

    # Collect proxy.yml from api container
    oc exec $pod -n $namespace -c api -- cat /etc/ansible-automation-platform/gateway/proxy.yml > "${BASE_COLLECTION_PATH}/configs/${pod}-api-proxy.yml" 2>/dev/null || echo "Failed to collect proxy.yml from gateway $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # Collect nginx.conf from proxy container
    oc exec $pod -n $namespace -c proxy -- cat /etc/nginx/nginx.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-proxy-nginx.conf" 2>/dev/null || echo "Failed to collect nginx.conf from gateway $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # Collect redis.conf if redis container exists
    oc exec $pod -n $namespace -c redis -- cat /etc/redis/redis.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-redis.conf" 2>/dev/null || echo "No redis container or redis.conf in gateway $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  done

  # Controller-web pods - collect redis.conf, nginx.conf, supervisord.conf
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=automationcontroller -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    # Check if this is a web pod (not task pod)
    if [[ "$pod" == *"web"* ]]; then
      echo "Collecting config files from controller web pod: $pod"

      # Get the web container name dynamically (it contains "-web" in the name)
      web_container=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[*].name}' 2>/dev/null | tr ' ' '\n' | grep -- '-web$' | head -1)

      if [ -z "$web_container" ]; then
        echo "Warning: Could not find web container in pod $pod, skipping config collection" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
        continue
      fi

      # Collect redis.conf from redis container
      oc exec $pod -n $namespace -c redis -- cat /etc/redis/redis.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-web-redis.conf" 2>/dev/null || echo "Failed to collect redis.conf from controller web $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

      # Collect nginx.conf
      oc exec $pod -n $namespace -c $web_container -- cat /etc/nginx/nginx.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-web-nginx.conf" 2>/dev/null || echo "Failed to collect nginx.conf from controller web $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

      # Collect supervisord.conf
      oc exec $pod -n $namespace -c $web_container -- cat /etc/supervisord.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-web-supervisord.conf" 2>/dev/null || echo "Failed to collect supervisord.conf from controller web $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
    fi
  done

  # Controller-task pods - collect receptor.conf, redis.conf, supervisord.conf
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=task -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting config files from controller task pod: $pod"

    # Get the task container name dynamically (it contains "-task" in the name)
    task_container=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[*].name}' 2>/dev/null | tr ' ' '\n' | grep -- '-task$' | head -1)

    if [ -z "$task_container" ]; then
      echo "Warning: Could not find task container in pod $pod, skipping config collection" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      continue
    fi

    # Collect receptor.conf
    oc exec $pod -n $namespace -c $task_container -- cat /etc/receptor/receptor.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-task-receptor.conf" 2>/dev/null || echo "Failed to collect receptor.conf from controller task $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # Collect redis.conf from redis container
    oc exec $pod -n $namespace -c redis -- cat /etc/redis/redis.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-task-redis.conf" 2>/dev/null || echo "Failed to collect redis.conf from controller task $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # Collect supervisord.conf
    oc exec $pod -n $namespace -c $task_container -- cat /etc/supervisord.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-task-supervisord.conf" 2>/dev/null || echo "Failed to collect supervisord.conf from controller task $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  done

  # Hub API pods - collect nginx.conf
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/name=automationhub-api -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting config files from hub API pod: $pod"

    # Collect nginx.conf
    oc exec $pod -n $namespace -c api -- cat /etc/nginx/nginx.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-api-nginx.conf" 2>/dev/null || echo "Failed to collect nginx.conf from hub API $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  done

  # EDA API pods - collect nginx.conf
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=eda-api -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting config files from EDA API pod: $pod"

    # Collect nginx.conf
    oc exec $pod -n $namespace -c nginx -- cat /etc/nginx/nginx.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-api-nginx.conf" 2>/dev/null || echo "Failed to collect nginx.conf from EDA API $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  done

  # Redis standalone pods - collect redis.conf
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/name=redis -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting config files from Redis pod: $pod"

    # Collect redis.conf
    oc exec $pod -n $namespace -c redis -- cat /etc/redis/redis.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-redis.conf" 2>/dev/null || echo "Failed to collect redis.conf from Redis $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  done
}

# Function to collect comprehensive management commands output
# Refactored to use configuration-driven approach based on aoc_azure_sosreport pattern
collect_management_commands() {
  local namespace=$1
  echo "Collecting management commands output for namespace: $namespace"

  # ========================================================================
  # Collect from automation controller task pods
  # ========================================================================
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=task -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    # Check if pod is running
    pod_phase=$(oc get pod $pod -n $namespace -o jsonpath='{.status.phase}' 2>/dev/null)
    if [ "$pod_phase" != "Running" ]; then
      echo "Skipping management commands for task pod $pod (status: $pod_phase)" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      continue
    fi

    # Get the task container name dynamically (it contains "-task" in the name)
    task_container=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[*].name}' 2>/dev/null | tr ' ' '\n' | grep -- '-task$' | head -1)

    if [ -z "$task_container" ]; then
      echo "Warning: Could not find task container in pod $pod, skipping management commands collection" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      continue
    fi

    # Execute all configured commands for this pod type
    exec_commands_for_pod "$pod" "$namespace" "$task_container" "CONTROLLER_TASK_COMMANDS"
  done

  # ========================================================================
  # Collect from automation controller web pods
  # ========================================================================
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=automationcontroller -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    # Check if this is a web pod (not task pod)
    if [[ "$pod" == *"web"* ]]; then
      # Check if pod is running
      pod_phase=$(oc get pod $pod -n $namespace -o jsonpath='{.status.phase}' 2>/dev/null)
      if [ "$pod_phase" != "Running" ]; then
        echo "Skipping management commands for web pod $pod (status: $pod_phase)" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
        continue
      fi

      # Get the web container name dynamically (it contains "-web" in the name)
      web_container=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[*].name}' 2>/dev/null | tr ' ' '\n' | grep -- '-web$' | head -1)

      if [ -z "$web_container" ]; then
        echo "Warning: Could not find web container in pod $pod, skipping management commands collection" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
        continue
      fi

      # Execute all configured commands for this pod type
      exec_commands_for_pod "$pod" "$namespace" "$web_container" "CONTROLLER_WEB_COMMANDS"
    fi
  done

  # ========================================================================
  # Collect from gateway pods
  # ========================================================================
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=aap-gateway -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    # Check if pod is running
    pod_phase=$(oc get pod $pod -n $namespace -o jsonpath='{.status.phase}' 2>/dev/null)
    if [ "$pod_phase" != "Running" ]; then
      echo "Skipping management commands for gateway pod $pod (status: $pod_phase)" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      continue
    fi

    # Execute all configured commands for this pod type
    exec_commands_for_pod "$pod" "$namespace" "api" "GATEWAY_COMMANDS"
  done

  # ========================================================================
  # Collect from automation hub API pods
  # ========================================================================
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/name=automationhub-api -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    # Check if pod is running
    pod_phase=$(oc get pod $pod -n $namespace -o jsonpath='{.status.phase}' 2>/dev/null)
    if [ "$pod_phase" != "Running" ]; then
      echo "Skipping management commands for hub API pod $pod (status: $pod_phase)" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      continue
    fi

    # Execute all configured commands for this pod type
    exec_commands_for_pod "$pod" "$namespace" "api" "HUB_COMMANDS"
  done

  # ========================================================================
  # Collect from EDA pods
  # ========================================================================
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=eda-api -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    # Check if pod is running
    pod_phase=$(oc get pod $pod -n $namespace -o jsonpath='{.status.phase}' 2>/dev/null)
    if [ "$pod_phase" != "Running" ]; then
      echo "Skipping management commands for EDA pod $pod (status: $pod_phase)" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      continue
    fi

    # Execute all configured commands for this pod type
    # Note: RBAC_checks may fail due to known platform issues (AAP-52870)
    exec_commands_for_pod "$pod" "$namespace" "eda-api" "EDA_COMMANDS"
  done
}

# Function to sanitize sensitive values in settings command outputs
# Based on the aoc_azure_sosreport sanitization pattern
sanitize_settings() {
  echo "Sanitizing sensitive values in settings command outputs..."

  if [ ! -d "${BASE_COLLECTION_PATH}/commands" ]; then
    echo "No commands directory found, skipping sanitization" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
    return
  fi

  # Sanitize Controller print_settings files
  for settings_file in ${BASE_COLLECTION_PATH}/commands/*-awx-*-print_settings.log; do
    if [ -f "$settings_file" ]; then
      echo "Sanitizing Controller settings: $(basename $settings_file)"

      # Create a temporary file for sed operations
      temp_file="${settings_file}.tmp"
      cp "$settings_file" "$temp_file"

      # Sanitize specific sensitive settings
      # Format: SETTING_NAME = 'value' or SETTING_NAME = "value"

      # SUBSCRIPTIONS_PASSWORD
      sed -i "s/\(SUBSCRIPTIONS_PASSWORD[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # PASSWORD in DATABASES dict (format: 'PASSWORD': 'value')
      sed -i "s/\('PASSWORD':[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # BROADCAST_WEBSOCKET_SECRET
      sed -i "s/\(BROADCAST_WEBSOCKET_SECRET[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # EMAIL_HOST_PASSWORD
      sed -i "s/\(EMAIL_HOST_PASSWORD[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # RADIUS_SECRET
      sed -i "s/\(RADIUS_SECRET[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # SECRET_KEY
      sed -i "s/\(SECRET_KEY[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # SOCIAL_AUTH_AZUREAD_OAUTH2_SECRET
      sed -i "s/\(SOCIAL_AUTH_AZUREAD_OAUTH2_SECRET[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # SOCIAL_AUTH_GITHUB_ENTERPRISE_ORG_SECRET
      sed -i "s/\(SOCIAL_AUTH_GITHUB_ENTERPRISE_ORG_SECRET[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # SOCIAL_AUTH_GITHUB_ENTERPRISE_SECRET
      sed -i "s/\(SOCIAL_AUTH_GITHUB_ENTERPRISE_SECRET[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # SOCIAL_AUTH_GITHUB_ENTERPRISE_TEAM_SECRET
      sed -i "s/\(SOCIAL_AUTH_GITHUB_ENTERPRISE_TEAM_SECRET[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # SOCIAL_AUTH_GITHUB_ORG_SECRET
      sed -i "s/\(SOCIAL_AUTH_GITHUB_ORG_SECRET[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # SOCIAL_AUTH_GITHUB_SECRET
      sed -i "s/\(SOCIAL_AUTH_GITHUB_SECRET[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # SOCIAL_AUTH_GITHUB_TEAM_SECRET
      sed -i "s/\(SOCIAL_AUTH_GITHUB_TEAM_SECRET[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET
      sed -i "s/\(SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # TACACSPLUS_SECRET
      sed -i "s/\(TACACSPLUS_SECRET[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # Move sanitized file back
      mv "$temp_file" "$settings_file"
      echo "Sanitized: $(basename $settings_file)" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
    fi
  done

  # Sanitize Hub diffsettings files
  for settings_file in ${BASE_COLLECTION_PATH}/commands/*-hub-diffsettings.log; do
    if [ -f "$settings_file" ]; then
      echo "Sanitizing Hub settings: $(basename $settings_file)"

      temp_file="${settings_file}.tmp"
      cp "$settings_file" "$temp_file"

      # Sanitize Hub-specific sensitive settings
      # Format: SETTING_NAME = 'value' or dict format

      # PASSWORD in DATABASES dict (format: 'PASSWORD': 'value')
      sed -i "s/\('PASSWORD':[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # SECRET_KEY (Django)
      sed -i "s/\(SECRET_KEY[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true
      sed -i "s/\('SECRET_KEY':[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # REDIS_PASSWORD
      sed -i "s/\(REDIS_PASSWORD[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # DB_ENCRYPTION_KEY
      sed -i "s/\(DB_ENCRYPTION_KEY[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # ANSIBLE_BASE_JWT_KEY
      sed -i "s/\(ANSIBLE_BASE_JWT_KEY[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # Move sanitized file back
      mv "$temp_file" "$settings_file"
      echo "Sanitized: $(basename $settings_file)" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
    fi
  done



  # Sanitize Hub redis.conf files
  for config_file in ${BASE_COLLECTION_PATH}/configs/*hub-redis*.conf; do
    if [ -f "$config_file" ]; then
      echo "Sanitizing Hub Redis config: $(basename $config_file)"

      temp_file="${config_file}.tmp"
      cp "$config_file" "$temp_file"

      # Sanitize Redis passwords
      # requirepass directive
      sed -i 's/^requirepass .*/requirepass *************/' "$temp_file" 2>/dev/null || true

      # masterauth directive
      sed -i 's/^masterauth .*/masterauth *************/' "$temp_file" 2>/dev/null || true

      # ACL user passwords (>password format)
      sed -i 's/>[^ ]*/>*************/' "$temp_file" 2>/dev/null || true

      # Move sanitized file back
      mv "$temp_file" "$config_file"
      echo "Sanitized: $(basename $config_file)" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
    fi
  done

  # Sanitize Gateway print_settings files
  for settings_file in ${BASE_COLLECTION_PATH}/commands/*-gateway-print_settings.log; do
    if [ -f "$settings_file" ]; then
      echo "Sanitizing Gateway settings: $(basename $settings_file)"

      temp_file="${settings_file}.tmp"
      cp "$settings_file" "$temp_file"

      # Sanitize Gateway-specific sensitive settings
      # Format: SETTING_NAME = 'value'

      # SECRET_KEY
      sed -i "s/\(SECRET_KEY[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # EMAIL_HOST_PASSWORD
      sed -i "s/\(EMAIL_HOST_PASSWORD[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # PASSWORD in DATABASES dict (format: 'PASSWORD': 'value')
      sed -i "s/\('PASSWORD':[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # Move sanitized file back
      mv "$temp_file" "$settings_file"
      echo "Sanitized: $(basename $settings_file)" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
    fi
  done

  # Sanitize EDA diffsettings files
  for settings_file in ${BASE_COLLECTION_PATH}/commands/*-eda-diffsettings.log; do
    if [ -f "$settings_file" ]; then
      echo "Sanitizing EDA settings: $(basename $settings_file)"

      temp_file="${settings_file}.tmp"
      cp "$settings_file" "$temp_file"

      # Sanitize EDA-specific sensitive settings
      # Format: SETTING_NAME = 'value' or SETTING_NAME = {...}

      # PG_NOTIFY_DSN
      sed -i "s/\(PG_NOTIFY_DSN[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # PG_NOTIFY_DSN_SERVER
      sed -i "s/\(PG_NOTIFY_DSN_SERVER[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # REDIS_USER_PASSWORD
      sed -i "s/\(REDIS_USER_PASSWORD[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # PASSWORD in DATABASES dict (format: 'PASSWORD': 'value')
      sed -i "s/\('PASSWORD':[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # SECRET_KEY (both standalone and in dict format)
      sed -i "s/\(SECRET_KEY[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true
      sed -i "s/\('SECRET_KEY':[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # CONTROLLER_TOKEN
      sed -i "s/\(CONTROLLER_TOKEN[[:space:]]*=[[:space:]]*\)['\"][^'\"]*['\"]/\1'*************'/g" "$temp_file" 2>/dev/null || true

      # Note: DATABASES and RQ_QUEUES are complex dicts - PASSWORD within them is sanitized above

      # Move sanitized file back
      mv "$temp_file" "$settings_file"
      echo "Sanitized: $(basename $settings_file)" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
    fi
  done

  echo "Sanitization complete" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
}

