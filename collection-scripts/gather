      for ac_file in $(find "$ns_dir/automationcontroller.ansible.com/automationcontrollers" -name "*.yaml" -type f | sort); do
        filename=$(basename "$ac_file")
        relative_path=$(echo "$ac_file" | sed "s|${BASE_COLLECTION_PATH}/||")
        echo "                <li><a href=\"../$relative_path\">$filename</a></li>" >> $NAMESPACE_HTML
        found_resources=true
      done
      echo "            </ul>" >> $NAMESPACE_HTML
    fi

    # AutomationHub instances
    if [ -d "$ns_dir/automationhub.ansible.com/automationhubs" ]; then
      echo "            <h3>AutomationHub</h3>" >> $NAMESPACE_HTML
      echo "            <ul>" >> $NAMESPACE_HTML
      for ah_file in $(find "$ns_dir/automationhub.ansible.com/automationhubs" -name "*.yaml" -type f | sort); do
        filename=$(basename "$ah_file")
        relative_path=$(echo "$ah_file" | sed "s|${BASE_COLLECTION_PATH}/||")
        echo "                <li><a href=\"../$relative_path\">$filename</a></li>" >> $NAMESPACE_HTML
        found_resources=true
      done
      echo "            </ul>" >> $NAMESPACE_HTML
