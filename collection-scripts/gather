# Function to create user-friendly directory structure
create_user_friendly_structure() {
  echo "Creating user-friendly directory structure..."

  # Create top-level directories
  mkdir -p "${BASE_COLLECTION_PATH}/summary"
  mkdir -p "${BASE_COLLECTION_PATH}/operators"
  mkdir -p "${BASE_COLLECTION_PATH}/cluster"
  mkdir -p "${BASE_COLLECTION_PATH}/crds"
  mkdir -p "${BASE_COLLECTION_PATH}/resources"

  # ========================================
  # 1. SUMMARY DIRECTORY
  # ========================================
  echo "Organizing summary information..."

  # Move/copy summary report to summary directory (keep original for backward compat)
  if [ -f "${BASE_COLLECTION_PATH}/reports/summary-report.html" ]; then
    cp "${BASE_COLLECTION_PATH}/reports/summary-report.html" "${BASE_COLLECTION_PATH}/summary/summary-report.html"
  fi

  # Create text summary
  cat > "${BASE_COLLECTION_PATH}/summary/summary.txt" << EOF
AAP Must-Gather Summary
Generated on: $(date)
================================================================================

NAMESPACES WITH AAP RESOURCES:
EOF

  # Add namespace list to summary
  for ns in $NS; do
    echo "  - $ns" >> "${BASE_COLLECTION_PATH}/summary/summary.txt"
  done

  # Collect all events from all AAP namespaces
  echo "" >> "${BASE_COLLECTION_PATH}/summary/summary.txt"
  echo "EVENTS SUMMARY:" >> "${BASE_COLLECTION_PATH}/summary/summary.txt"
  echo "See events-all.txt and events-warnings.txt for detailed event information" >> "${BASE_COLLECTION_PATH}/summary/summary.txt"

  # Create consolidated events files
  > "${BASE_COLLECTION_PATH}/summary/events-all.txt"
  > "${BASE_COLLECTION_PATH}/summary/events-warnings.txt"

  for ns in $NS; do
    echo "==============================================================================" >> "${BASE_COLLECTION_PATH}/summary/events-all.txt"
    echo "NAMESPACE: $ns" >> "${BASE_COLLECTION_PATH}/summary/events-all.txt"
    echo "==============================================================================" >> "${BASE_COLLECTION_PATH}/summary/events-all.txt"
    oc get events -n $ns --sort-by='.lastTimestamp' >> "${BASE_COLLECTION_PATH}/summary/events-all.txt" 2>/dev/null || echo "No events found in namespace $ns" >> "${BASE_COLLECTION_PATH}/summary/events-all.txt"
    echo "" >> "${BASE_COLLECTION_PATH}/summary/events-all.txt"

    # Warning events only
    echo "==============================================================================" >> "${BASE_COLLECTION_PATH}/summary/events-warnings.txt"
    echo "NAMESPACE: $ns - WARNING EVENTS" >> "${BASE_COLLECTION_PATH}/summary/events-warnings.txt"
    echo "==============================================================================" >> "${BASE_COLLECTION_PATH}/summary/events-warnings.txt"
    oc get events -n $ns --field-selector type=Warning --sort-by='.lastTimestamp' >> "${BASE_COLLECTION_PATH}/summary/events-warnings.txt" 2>/dev/null || echo "No warning events found in namespace $ns" >> "${BASE_COLLECTION_PATH}/summary/events-warnings.txt"
    echo "" >> "${BASE_COLLECTION_PATH}/summary/events-warnings.txt"
  done

  # Collect node information
  echo "Collecting node information..."
  oc get nodes -o wide > "${BASE_COLLECTION_PATH}/summary/nodes.txt" 2>/dev/null || echo "Failed to collect node information" > "${BASE_COLLECTION_PATH}/summary/nodes.txt"

  # Copy namespace YAML for first AAP namespace (or all if multiple)
  for ns in $NS; do
    if [ -f "${BASE_COLLECTION_PATH}/must-gather/namespaces/${ns}/${ns}.yaml" ]; then
      cp "${BASE_COLLECTION_PATH}/must-gather/namespaces/${ns}/${ns}.yaml" "${BASE_COLLECTION_PATH}/summary/namespace-${ns}.yaml"
    fi
  done

  # ========================================
  # 2. OPERATORS DIRECTORY
  # ========================================
  echo "Organizing operator information..."

  # Collect operator information from all AAP namespaces
  > "${BASE_COLLECTION_PATH}/operators/csv.yaml"
  > "${BASE_COLLECTION_PATH}/operators/subscriptions.yaml"
  > "${BASE_COLLECTION_PATH}/operators/installplans.yaml"
  > "${BASE_COLLECTION_PATH}/operators/pods.yaml"

  for ns in $NS; do
    echo "---" >> "${BASE_COLLECTION_PATH}/operators/csv.yaml"
    echo "# Namespace: $ns" >> "${BASE_COLLECTION_PATH}/operators/csv.yaml"
    oc get csv -n $ns -o yaml >> "${BASE_COLLECTION_PATH}/operators/csv.yaml" 2>/dev/null || echo "# No CSV found in $ns" >> "${BASE_COLLECTION_PATH}/operators/csv.yaml"

    echo "---" >> "${BASE_COLLECTION_PATH}/operators/subscriptions.yaml"
    echo "# Namespace: $ns" >> "${BASE_COLLECTION_PATH}/operators/subscriptions.yaml"
    oc get subscriptions -n $ns -o yaml >> "${BASE_COLLECTION_PATH}/operators/subscriptions.yaml" 2>/dev/null || echo "# No subscriptions found in $ns" >> "${BASE_COLLECTION_PATH}/operators/subscriptions.yaml"

    echo "---" >> "${BASE_COLLECTION_PATH}/operators/installplans.yaml"
    echo "# Namespace: $ns" >> "${BASE_COLLECTION_PATH}/operators/installplans.yaml"
    oc get installplans -n $ns -o yaml >> "${BASE_COLLECTION_PATH}/operators/installplans.yaml" 2>/dev/null || echo "# No installplans found in $ns" >> "${BASE_COLLECTION_PATH}/operators/installplans.yaml"

    echo "==============================================================================" >> "${BASE_COLLECTION_PATH}/operators/pods.yaml"
    echo "# Namespace: $ns - Operator Pods" >> "${BASE_COLLECTION_PATH}/operators/pods.yaml"
    echo "==============================================================================" >> "${BASE_COLLECTION_PATH}/operators/pods.yaml"
    oc get pods -n $ns -l 'app.kubernetes.io/part-of in (aap-operator, ansible-automation-platform-operator)' -o yaml >> "${BASE_COLLECTION_PATH}/operators/pods.yaml" 2>/dev/null || echo "# No operator pods found in $ns" >> "${BASE_COLLECTION_PATH}/operators/pods.yaml"
    echo "" >> "${BASE_COLLECTION_PATH}/operators/pods.yaml"
  done

  # ========================================
  # 3. CLUSTER DIRECTORY
  # ========================================
  echo "Organizing cluster information..."

  # Copy cluster version
  if [ -f "${BASE_COLLECTION_PATH}/must-gather/cluster-scoped-resources/config.openshift.io/clusterversions/version.yaml" ]; then
    cp "${BASE_COLLECTION_PATH}/must-gather/cluster-scoped-resources/config.openshift.io/clusterversions/version.yaml" "${BASE_COLLECTION_PATH}/cluster/version.yaml"
  fi

  # Move dmesg logs if they exist
  if [ -f "${BASE_COLLECTION_PATH}/master_dmesg.log" ]; then
    cp "${BASE_COLLECTION_PATH}/master_dmesg.log" "${BASE_COLLECTION_PATH}/cluster/master-dmesg.log"
  fi
  if [ -f "${BASE_COLLECTION_PATH}/worker_dmesg.log" ]; then
    cp "${BASE_COLLECTION_PATH}/worker_dmesg.log" "${BASE_COLLECTION_PATH}/cluster/worker-dmesg.log"
  fi

  # Copy API discovery
  if [ -f "${BASE_COLLECTION_PATH}/must-gather/aggregated-discovery-apis.yaml" ]; then
    cp "${BASE_COLLECTION_PATH}/must-gather/aggregated-discovery-apis.yaml" "${BASE_COLLECTION_PATH}/cluster/api-discovery.yaml"
  fi

  # ========================================
  # 4. CRDS DIRECTORY
  # ========================================
  echo "Organizing CRD information..."

  mkdir -p "${BASE_COLLECTION_PATH}/crds/definitions"

  # Create consolidated CRD list
  > "${BASE_COLLECTION_PATH}/crds/all-crds.txt"
  echo "AAP-Related Custom Resource Definitions" >> "${BASE_COLLECTION_PATH}/crds/all-crds.txt"
  echo "========================================" >> "${BASE_COLLECTION_PATH}/crds/all-crds.txt"
  echo "" >> "${BASE_COLLECTION_PATH}/crds/all-crds.txt"

  # Copy CRD definitions and list them
  CRD_PATH="${BASE_COLLECTION_PATH}/must-gather/cluster-scoped-resources/apiextensions.k8s.io/customresourcedefinitions"
  if [ -d "$CRD_PATH" ]; then
    for crd_file in "$CRD_PATH"/*.yaml; do
      if [ -f "$crd_file" ]; then
        crd_name=$(basename "$crd_file")
        cp "$crd_file" "${BASE_COLLECTION_PATH}/crds/definitions/$crd_name"
        echo "  - $crd_name" >> "${BASE_COLLECTION_PATH}/crds/all-crds.txt"
      fi
    done
  fi

  # ========================================
  # 5. RESOURCES DIRECTORY (already exists, just organize)
  # ========================================
  echo "Organizing resource status files..."

  # Move resource status files to resources directory if not already there
  for resource_file in deployments.log services.log routes.log ingress.log configmaps.log secrets.log pvc-status.log; do
    if [ -f "${BASE_COLLECTION_PATH}/$resource_file" ] && [ ! -f "${BASE_COLLECTION_PATH}/resources/$resource_file" ]; then
      cp "${BASE_COLLECTION_PATH}/$resource_file" "${BASE_COLLECTION_PATH}/resources/$resource_file"
    fi
  done

  # Move pod-status directory
  if [ -d "${BASE_COLLECTION_PATH}/pod-status" ]; then
    mkdir -p "${BASE_COLLECTION_PATH}/resources/pods"
    cp -r "${BASE_COLLECTION_PATH}/pod-status"/* "${BASE_COLLECTION_PATH}/resources/pods/" 2>/dev/null || true
  fi

  echo "User-friendly directory structure created successfully"
}

# Function to create namespace-specific user-friendly structure
create_namespace_structure() {
  local namespace=$1
  echo "Creating user-friendly structure for namespace: $namespace"

  # Create namespace directory
  mkdir -p "${BASE_COLLECTION_PATH}/namespaces/${namespace}"
  mkdir -p "${BASE_COLLECTION_PATH}/namespaces/${namespace}/logs"
  mkdir -p "${BASE_COLLECTION_PATH}/namespaces/${namespace}/configs"
  mkdir -p "${BASE_COLLECTION_PATH}/namespaces/${namespace}/commands"

  # ========================================
  # ORGANIZE LOGS
  # ========================================
  # Create flattened log structure with symlinks to must-gather logs
  MUST_GATHER_NS_PATH="${BASE_COLLECTION_PATH}/must-gather/namespaces/${namespace}"

  if [ -d "$MUST_GATHER_NS_PATH/pods" ]; then
    for pod_dir in "$MUST_GATHER_NS_PATH/pods"/*; do
      if [ -d "$pod_dir" ]; then
        pod_name=$(basename "$pod_dir")
        mkdir -p "${BASE_COLLECTION_PATH}/namespaces/${namespace}/logs/${pod_name}"

        # Find all container logs and create symlinks
        find "$pod_dir" -type f -name "*.log" 2>/dev/null | while read log_file; do
          # Extract container name and log type from path
          # Path format: pods/<pod>/<container>/<container>/logs/<type>.log
          container_path=$(echo "$log_file" | sed "s|$pod_dir/||" | sed 's|/logs/.*||')
          container_name=$(basename "$container_path")
          log_type=$(basename "$log_file" .log)

          # Create descriptive filename
          if [ "$log_type" = "current" ]; then
            link_name="${container_name}.log"
          elif [ "$log_type" = "previous" ]; then
            link_name="${container_name}-previous.log"
          elif [ "$log_type" = "previous.insecure" ]; then
            link_name="${container_name}-previous-insecure.log"
          else
            link_name="${container_name}-${log_type}.log"
          fi

          # Create relative symlink
          rel_path=$(realpath --relative-to="${BASE_COLLECTION_PATH}/namespaces/${namespace}/logs/${pod_name}" "$log_file")
          ln -sf "$rel_path" "${BASE_COLLECTION_PATH}/namespaces/${namespace}/logs/${pod_name}/${link_name}" 2>/dev/null || true
        done
      fi
    done
  fi

  # Also link logs from the flat logs directory at root
  if [ -d "${BASE_COLLECTION_PATH}/logs" ]; then
    for log_file in "${BASE_COLLECTION_PATH}/logs"/*; do
      if [ -f "$log_file" ]; then
        filename=$(basename "$log_file")
        # Extract pod name (format: podname-containername-suffix.log)
        # Check if this log belongs to this namespace by checking if pod exists in must-gather
        pod_prefix=$(echo "$filename" | sed 's/-operator.*//' | sed 's/-init.*//' | sed 's/-previous.*//')

        if [ -d "$MUST_GATHER_NS_PATH/pods/$pod_prefix"* ] 2>/dev/null; then
          # Find the actual pod directory
          for pod_dir in "$MUST_GATHER_NS_PATH/pods"/${pod_prefix}*; do
            if [ -d "$pod_dir" ]; then
              pod_name=$(basename "$pod_dir")
              mkdir -p "${BASE_COLLECTION_PATH}/namespaces/${namespace}/logs/${pod_name}"

              # Create symlink if not already exists
              if [ ! -f "${BASE_COLLECTION_PATH}/namespaces/${namespace}/logs/${pod_name}/${filename}" ]; then
                rel_path=$(realpath --relative-to="${BASE_COLLECTION_PATH}/namespaces/${namespace}/logs/${pod_name}" "$log_file")
                ln -sf "$rel_path" "${BASE_COLLECTION_PATH}/namespaces/${namespace}/logs/${pod_name}/${filename}" 2>/dev/null || true
              fi
            fi
          done
        fi
      fi
    done
  fi

  # ========================================
  # ORGANIZE CONFIGS
  # ========================================
  # Link config files from configs directory
  if [ -d "${BASE_COLLECTION_PATH}/configs" ]; then
    for config_file in "${BASE_COLLECTION_PATH}/configs"/*; do
      if [ -f "$config_file" ]; then
        filename=$(basename "$config_file")
        # Extract pod name (format: podname-container-configname)
        pod_name=$(echo "$filename" | cut -d'-' -f1-5)  # Adjust based on naming pattern

        # Check if this config belongs to a pod in this namespace
        if [ -d "$MUST_GATHER_NS_PATH/pods/$pod_name"* ] 2>/dev/null; then
          for pod_dir in "$MUST_GATHER_NS_PATH/pods"/${pod_name}*; do
            if [ -d "$pod_dir" ]; then
              actual_pod_name=$(basename "$pod_dir")
              mkdir -p "${BASE_COLLECTION_PATH}/namespaces/${namespace}/configs/${actual_pod_name}"

              # Create symlink
              rel_path=$(realpath --relative-to="${BASE_COLLECTION_PATH}/namespaces/${namespace}/configs/${actual_pod_name}" "$config_file")
              ln -sf "$rel_path" "${BASE_COLLECTION_PATH}/namespaces/${namespace}/configs/${actual_pod_name}/${filename}" 2>/dev/null || true
            fi
          done
        fi
      fi
    done
  fi

  # ========================================
  # ORGANIZE COMMANDS
  # ========================================
  # Link command output files from commands directory
  if [ -d "${BASE_COLLECTION_PATH}/commands" ]; then
    # Create subdirectories for each component type
    mkdir -p "${BASE_COLLECTION_PATH}/namespaces/${namespace}/commands/controller"
    mkdir -p "${BASE_COLLECTION_PATH}/namespaces/${namespace}/commands/eda"
    mkdir -p "${BASE_COLLECTION_PATH}/namespaces/${namespace}/commands/gateway"
    mkdir -p "${BASE_COLLECTION_PATH}/namespaces/${namespace}/commands/hub"

    for cmd_file in "${BASE_COLLECTION_PATH}/commands"/*; do
      if [ -f "$cmd_file" ]; then
        filename=$(basename "$cmd_file")

        # Determine component type and create symlink
        if [[ "$filename" == *"controller"* ]]; then
          rel_path=$(realpath --relative-to="${BASE_COLLECTION_PATH}/namespaces/${namespace}/commands/controller" "$cmd_file")
          ln -sf "$rel_path" "${BASE_COLLECTION_PATH}/namespaces/${namespace}/commands/controller/${filename}" 2>/dev/null || true
        elif [[ "$filename" == *"eda"* ]]; then
          rel_path=$(realpath --relative-to="${BASE_COLLECTION_PATH}/namespaces/${namespace}/commands/eda" "$cmd_file")
          ln -sf "$rel_path" "${BASE_COLLECTION_PATH}/namespaces/${namespace}/commands/eda/${filename}" 2>/dev/null || true
        elif [[ "$filename" == *"gateway"* ]]; then
          rel_path=$(realpath --relative-to="${BASE_COLLECTION_PATH}/namespaces/${namespace}/commands/gateway" "$cmd_file")
          ln -sf "$rel_path" "${BASE_COLLECTION_PATH}/namespaces/${namespace}/commands/gateway/${filename}" 2>/dev/null || true
        elif [[ "$filename" == *"hub"* ]]; then
          rel_path=$(realpath --relative-to="${BASE_COLLECTION_PATH}/namespaces/${namespace}/commands/hub" "$cmd_file")
          ln -sf "$rel_path" "${BASE_COLLECTION_PATH}/namespaces/${namespace}/commands/hub/${filename}" 2>/dev/null || true
        fi
      fi
    done
  fi

  echo "Namespace structure created for: $namespace"
}

