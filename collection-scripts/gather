  elif [ -f "${BASE_COLLECTION_PATH}/timestamp" ]; then
    echo "                <li><a href=\"timestamp\">⏰ Collection Timestamp</a> - When the data was collected</li>" >> $INDEX_FILE
  fi

  cat >> $INDEX_FILE << 'EOF'
            </ul>
        </div>

        <div class="section">
            <h2>ℹ️ How to Use This Must-Gather</h2>
            <ol>
                <li><strong>Review AAP Installations</strong> - Check the operator summary table for version and scope information</li>
