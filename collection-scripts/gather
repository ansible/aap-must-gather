        echo "            <h3>Automation Hub Configuration</h3>" >> $NAMESPACE_HTML
        echo "            <ul>" >> $NAMESPACE_HTML
        for configfile in $(echo $hub_configs | tr ' ' '\n' | sort); do
          filename=$(basename "$configfile")
          relative_path=$(echo "$configfile" | sed "s|${BASE_COLLECTION_PATH}/||")

          # Create descriptive display names
          display_name="$filename"
          if [[ "$filename" == *"nginx.conf"* ]]; then
            display_name="$(echo "$filename" | sed 's/-.*-nginx.conf/ - Nginx Configuration/')"
          fi

          echo "                <li><a href=\"../$relative_path.html\">$display_name</a></li>" >> $NAMESPACE_HTML
          found_configs=true
        done
        echo "            </ul>" >> $NAMESPACE_HTML
      fi

      # EDA configs - filter by pods in this namespace
      eda_configs=""
      for pod in $namespace_pods; do
        pod_eda_configs=$(find ${BASE_COLLECTION_PATH}/configs -maxdepth 1 -name "${pod}-*eda*.conf" -type f 2>/dev/null)
        if [ -n "$pod_eda_configs" ]; then
          eda_configs="$eda_configs $pod_eda_configs"
        fi
      done

      if [ -n "$eda_configs" ]; then
        echo "            <h3>Event-Driven Automation Configuration</h3>" >> $NAMESPACE_HTML
        echo "            <ul>" >> $NAMESPACE_HTML
        for configfile in $(echo $eda_configs | tr ' ' '\n' | sort); do
          filename=$(basename "$configfile")
          relative_path=$(echo "$configfile" | sed "s|${BASE_COLLECTION_PATH}/||")

          # Create descriptive display names
          display_name="$filename"
          if [[ "$filename" == *"nginx.conf"* ]]; then
            display_name="$(echo "$filename" | sed 's/-api-nginx.conf/ - Nginx Configuration/')"
          fi

          echo "                <li><a href=\"../$relative_path.html\">$display_name</a></li>" >> $NAMESPACE_HTML
          found_configs=true
        done
        echo "            </ul>" >> $NAMESPACE_HTML
      fi

      # Redis standalone configs - filter by pods in this namespace
      redis_configs=""
      for pod in $namespace_pods; do
        pod_redis_configs=$(find ${BASE_COLLECTION_PATH}/configs -maxdepth 1 -name "${pod}-*redis*.conf" -type f 2>/dev/null | grep -v controller | grep -v gateway)
        if [ -n "$pod_redis_configs" ]; then
          redis_configs="$redis_configs $pod_redis_configs"
        fi
      done

      if [ -n "$redis_configs" ]; then
        echo "            <h3>Redis Configuration</h3>" >> $NAMESPACE_HTML
        echo "            <ul>" >> $NAMESPACE_HTML
        for configfile in $(echo $redis_configs | tr ' ' '\n' | sort); do
          filename=$(basename "$configfile")
          relative_path=$(echo "$configfile" | sed "s|${BASE_COLLECTION_PATH}/||")

          display_name="$(echo "$filename" | sed 's/-redis.conf/ - Redis Configuration/')"

          echo "                <li><a href=\"../$relative_path.html\">$display_name</a></li>" >> $NAMESPACE_HTML
          found_configs=true
        done
        echo "            </ul>" >> $NAMESPACE_HTML
      fi
    fi

    if [ "$found_configs" = false ]; then
      echo "            <p><em>No configuration files found for this namespace.</em></p>" >> $NAMESPACE_HTML
      echo "            <p><strong>Note:</strong> Configuration files are collected from running AAP component pods. If no configs are shown, the components may not be running or accessible.</p>" >> $NAMESPACE_HTML
    fi

    echo "        </div>" >> $NAMESPACE_HTML

    # Add Kubernetes Resources section
    echo "        <div class=\"section\">" >> $NAMESPACE_HTML
    echo "            <h2>Kubernetes Resources</h2>" >> $NAMESPACE_HTML
    echo "            <p>Status and configuration of Kubernetes resources in this namespace:</p>" >> $NAMESPACE_HTML
    echo "            <ul>" >> $NAMESPACE_HTML

    # Check if namespace-specific resource files exist
    if [ -f "${BASE_COLLECTION_PATH}/resources/pvcs.log" ]; then
      echo "                <li><a href=\"../resources/pvcs.log.html#$namespace\">PVC Status</a></li>" >> $NAMESPACE_HTML
    fi
    if [ -f "${BASE_COLLECTION_PATH}/resources/deployments.log" ]; then
      echo "                <li><a href=\"../resources/deployments.log.html#$namespace\">Deployments</a></li>" >> $NAMESPACE_HTML
    fi
    if [ -f "${BASE_COLLECTION_PATH}/resources/services.log" ]; then
      echo "                <li><a href=\"../resources/services.log.html#$namespace\">Services</a></li>" >> $NAMESPACE_HTML
    fi
    if [ -f "${BASE_COLLECTION_PATH}/resources/routes.log" ]; then
      echo "                <li><a href=\"../resources/routes.log.html#$namespace\">Routes</a></li>" >> $NAMESPACE_HTML
    fi
    if [ -f "${BASE_COLLECTION_PATH}/resources/configmaps.log" ]; then
      echo "                <li><a href=\"../resources/configmaps.log.html#$namespace\">ConfigMaps</a></li>" >> $NAMESPACE_HTML
    fi
    if [ -f "${BASE_COLLECTION_PATH}/resources/secrets.log" ]; then
      echo "                <li><a href=\"../resources/secrets.log.html#$namespace\">Secrets</a></li>" >> $NAMESPACE_HTML
    fi
    if [ -f "${BASE_COLLECTION_PATH}/resources/ingress.log" ]; then
      echo "                <li><a href=\"../resources/ingress.log.html#$namespace\">Ingress</a></li>" >> $NAMESPACE_HTML
    fi

    # Link to pod status for this namespace
    if [ -f "${BASE_COLLECTION_PATH}/pod-status/${namespace}-pods.log" ]; then
      echo "                <li><a href=\"../pod-status/${namespace}-pods.log.html\">Pod Status</a></li>" >> $NAMESPACE_HTML
    fi

    echo "            </ul>" >> $NAMESPACE_HTML

    # Add note with link to browse all resources
    relative_ns_path=$(echo "$ns_dir" | sed "s|${BASE_COLLECTION_PATH}/||")
    echo "            <p class=\"note\" style=\"margin-top: 10px; padding: 10px; background-color: #f0f0f0; border-left: 4px solid #667eea;\"><strong>Note:</strong> For complete resource dumps, <a href=\"../$relative_ns_path/\">browse all resources for $namespace</a>.</p>" >> $NAMESPACE_HTML

    echo "        </div>" >> $NAMESPACE_HTML

    # Close the HTML
    cat >> $NAMESPACE_HTML << 'EOF'
    </div>
</body>
</html>
EOF

    echo "Generated namespace page: $NAMESPACE_HTML"
  done
}

