        echo "                <li><a href=\"../$relative_path\">$filename</a></li>" >> $NAMESPACE_HTML
        found_resources=true
      done
      echo "            </ul>" >> $NAMESPACE_HTML
    fi

    if [ "$found_resources" = false ]; then
      echo "            <p><em>No AAP custom resources found in this namespace.</em></p>" >> $NAMESPACE_HTML
    fi

    echo "        </div>" >> $NAMESPACE_HTML

    # Add Operator Information section
    echo "        <div class=\"section\">" >> $NAMESPACE_HTML
    echo "            <h2>🔧 Operator Information</h2>" >> $NAMESPACE_HTML

    # Check for subscription information
    subscription_file="$ns_dir/operators.coreos.com/subscriptions/ansible-automation-platform-operator.yaml"
    if [ -f "$subscription_file" ]; then
      channel=$(grep "^  channel:" "$subscription_file" | awk '{print $2}' || echo "Unknown")
      source=$(grep "^  source:" "$subscription_file" | awk '{print $2}' || echo "Unknown")
      installed_csv=$(grep "^  installedCSV:" "$subscription_file" | awk '{print $2}' || echo "Unknown")

      echo "            <table>" >> $NAMESPACE_HTML
      echo "                <tr><th>Property</th><th>Value</th></tr>" >> $NAMESPACE_HTML
      echo "                <tr><td>Channel</td><td>$channel</td></tr>" >> $NAMESPACE_HTML
      echo "                <tr><td>Source</td><td>$source</td></tr>" >> $NAMESPACE_HTML
      echo "                <tr><td>Installed CSV</td><td>$installed_csv</td></tr>" >> $NAMESPACE_HTML
      echo "            </table>" >> $NAMESPACE_HTML

      relative_sub_path=$(echo "$subscription_file" | sed "s|${BASE_COLLECTION_PATH}/||")
      echo "            <p><a href=\"../$relative_sub_path\">📄 View Subscription Details</a></p>" >> $NAMESPACE_HTML
    else
      echo "            <p><em>No AAP operator subscription found in this namespace.</em></p>" >> $NAMESPACE_HTML
    fi

    echo "        </div>" >> $NAMESPACE_HTML

    # Add Pod Status section
    echo "        <div class=\"section\">" >> $NAMESPACE_HTML
    echo "            <h2>🚀 Pod Status</h2>" >> $NAMESPACE_HTML
    echo "            <p>Current status of all pods in this namespace (useful for identifying crashing pods):</p>" >> $NAMESPACE_HTML

    # Check for dedicated pod status file
    pod_status_file="${BASE_COLLECTION_PATH}/pod-status/${namespace}-pods.log"
    pod_info_found=false

    if [ -f "$pod_status_file" ]; then
      echo "            <h3>Pod Status Summary</h3>" >> $NAMESPACE_HTML
      echo "            <pre style=\"background-color: #f8f9fa; padding: 10px; border-radius: 4px; overflow-x: auto; font-family: 'Courier New', monospace; font-size: 12px; white-space: pre;\">" >> $NAMESPACE_HTML

      # Read the pod status file and display it with proper column alignment
      pod_content=$(cat "$pod_status_file" 2>/dev/null)
      if [ -n "$pod_content" ] && [ "$pod_content" != "No pods found in namespace $namespace" ]; then
        # Use column command to align the output properly
        echo "$pod_content" | column -t >> $NAMESPACE_HTML
        pod_info_found=true
      else
        echo "No pods found in namespace: $namespace" >> $NAMESPACE_HTML
      fi

      echo "            </pre>" >> $NAMESPACE_HTML

      # Add link to the raw pod status file
      relative_pod_path=$(echo "$pod_status_file" | sed "s|${BASE_COLLECTION_PATH}/||")
      echo "            <p><a href=\"../$relative_pod_path\">📄 View raw pod status file</a></p>" >> $NAMESPACE_HTML
    fi

    if [ "$pod_info_found" = false ]; then
      echo "            <p><em>No pod information found for this namespace in the collected data.</em></p>" >> $NAMESPACE_HTML
      echo "            <p><strong>Note:</strong> To see current pod status, run: <code>oc get pods -n $namespace</code></p>" >> $NAMESPACE_HTML
    fi

    echo "        </div>" >> $NAMESPACE_HTML

    # Add Logs section
    echo "        <div class=\"section\">" >> $NAMESPACE_HTML
    echo "            <h2>📋 Logs</h2>" >> $NAMESPACE_HTML

    # Find operator logs first (these are most important for troubleshooting)
    found_operator_logs=false
    if [ -d "${BASE_COLLECTION_PATH}/logs" ]; then
      # Look for operator pod logs in this namespace
      operator_logs=$(find ${BASE_COLLECTION_PATH}/logs -name "*operator*" -name "*.log" -type f | grep -E "(${namespace}|operator)" | sort)

      if [ -n "$operator_logs" ]; then
        echo "            <h3>🔧 Operator Pod Logs</h3>" >> $NAMESPACE_HTML
        echo "            <p>Latest logs from AAP operator pods (most useful for troubleshooting operator issues):</p>" >> $NAMESPACE_HTML
        echo "            <ul>" >> $NAMESPACE_HTML

        for logfile in $operator_logs; do
          filename=$(basename "$logfile")
          relative_path=$(echo "$logfile" | sed "s|${BASE_COLLECTION_PATH}/||")

          # Create a more readable display name for operator logs
          display_name="$filename"
          if [[ "$filename" == *"operator-controller-manager"* ]]; then
            if [[ "$filename" == *"previous"* ]]; then
              display_name="🔄 $(echo "$filename" | sed 's/-operator.*/ (Previous Log)/')"
            else
              display_name="📋 $(echo "$filename" | sed 's/-operator.*/ (Current Log)/')"
            fi
          fi

          echo "                <li><a href=\"../$relative_path\">$display_name</a></li>" >> $NAMESPACE_HTML
          found_operator_logs=true
        done
        echo "            </ul>" >> $NAMESPACE_HTML
      fi
    fi

    # Find pod container and initContainer logs
    found_container_logs=false
    if [ -d "${BASE_COLLECTION_PATH}/logs" ]; then
      # Look for container logs (both regular containers and initContainers)
      container_logs=$(find ${BASE_COLLECTION_PATH}/logs -name "*.log" -type f | grep -E "(${namespace}|container|init)" | grep -v operator | sort)

      if [ -n "$container_logs" ]; then
        echo "            <h3>📦 Pod Container Logs</h3>" >> $NAMESPACE_HTML
        echo "            <p>Logs from pod containers and initContainers in this namespace:</p>" >> $NAMESPACE_HTML
        echo "            <ul>" >> $NAMESPACE_HTML

        for logfile in $container_logs; do
          filename=$(basename "$logfile")
          relative_path=$(echo "$logfile" | sed "s|${BASE_COLLECTION_PATH}/||")

          # Create more descriptive display names for container logs
          display_name="$filename"
          if [[ "$filename" == *"init"* ]]; then
            display_name="🔄 $filename (initContainer)"
          elif [[ "$filename" == *"container"* ]]; then
            display_name="📦 $filename (container)"
          else
            display_name="📋 $filename"
          fi

          echo "                <li><a href=\"../$relative_path\">$display_name</a></li>" >> $NAMESPACE_HTML
          found_container_logs=true
        done
        echo "            </ul>" >> $NAMESPACE_HTML
      fi
    fi

    # Find other application logs related to this namespace
    found_app_logs=false
    if [ -d "${BASE_COLLECTION_PATH}/logs" ]; then
      # Look for non-operator, non-container logs related to this namespace
      app_logs=$(find ${BASE_COLLECTION_PATH}/logs -name "*${namespace}*" -name "*.log" -type f | grep -v operator | grep -v -E "(container|init)" | sort)

      if [ -n "$app_logs" ]; then
        echo "            <h3>📋 Application Logs</h3>" >> $NAMESPACE_HTML
        echo "            <p>Other logs from AAP application components:</p>" >> $NAMESPACE_HTML
        echo "            <ul>" >> $NAMESPACE_HTML

        for logfile in $app_logs; do
          filename=$(basename "$logfile")
          relative_path=$(echo "$logfile" | sed "s|${BASE_COLLECTION_PATH}/||")
          echo "                <li><a href=\"../$relative_path\">$filename</a></li>" >> $NAMESPACE_HTML
          found_app_logs=true
        done
        echo "            </ul>" >> $NAMESPACE_HTML
      fi
    fi

    if [ "$found_operator_logs" = false ] && [ "$found_container_logs" = false ] && [ "$found_app_logs" = false ]; then
      echo "            <p><em>No logs found for this namespace.</em></p>" >> $NAMESPACE_HTML
    fi

    echo "        </div>" >> $NAMESPACE_HTML

    # Add Commands section
    echo "        <div class=\"section\">" >> $NAMESPACE_HTML
    echo "            <h2>⚙️ Management Command Outputs</h2>" >> $NAMESPACE_HTML
    echo "            <p>Output from AAP management commands run against components in this namespace:</p>" >> $NAMESPACE_HTML

    # Find command outputs related to this namespace
    found_commands=false
    if [ -d "${BASE_COLLECTION_PATH}/commands" ]; then

      # Group commands by component type
      # Controller commands
      controller_commands=$(find ${BASE_COLLECTION_PATH}/commands -name "*awx*" -name "*.log" -type f | sort)
      if [ -n "$controller_commands" ]; then
        echo "            <h3>🎮 Automation Controller Commands</h3>" >> $NAMESPACE_HTML
        echo "            <ul>" >> $NAMESPACE_HTML
        for cmdfile in $controller_commands; do
          filename=$(basename "$cmdfile")
          relative_path=$(echo "$cmdfile" | sed "s|${BASE_COLLECTION_PATH}/||")

          # Create descriptive display names
          display_name="$filename"
          if [[ "$filename" == *"showmigrations"* ]]; then
            display_name="📊 $(echo "$filename" | sed 's/-awx.*/ - Database Migrations/')"
          elif [[ "$filename" == *"version"* ]]; then
            display_name="🏷️ $(echo "$filename" | sed 's/-awx.*/ - Version Info/')"
          elif [[ "$filename" == *"dbcheck"* ]]; then
            display_name="🔍 $(echo "$filename" | sed 's/-awx.*/ - Database Check/')"
          fi

          echo "                <li><a href=\"../$relative_path\">$display_name</a></li>" >> $NAMESPACE_HTML
          found_commands=true
        done
        echo "            </ul>" >> $NAMESPACE_HTML
      fi

      # Gateway commands
      gateway_commands=$(find ${BASE_COLLECTION_PATH}/commands -name "*gateway*" -name "*.log" -type f | sort)
      if [ -n "$gateway_commands" ]; then
        echo "            <h3>🌐 AAP Gateway Commands</h3>" >> $NAMESPACE_HTML
        echo "            <ul>" >> $NAMESPACE_HTML
        for cmdfile in $gateway_commands; do
          filename=$(basename "$cmdfile")
          relative_path=$(echo "$cmdfile" | sed "s|${BASE_COLLECTION_PATH}/||")

          # Create descriptive display names
          display_name="$filename"
          if [[ "$filename" == *"showmigrations"* ]]; then
            display_name="📊 $(echo "$filename" | sed 's/-gateway.*/ - Database Migrations/')"
          elif [[ "$filename" == *"version"* ]]; then
            display_name="🏷️ $(echo "$filename" | sed 's/-gateway.*/ - Version Info/')"
          elif [[ "$filename" == *"dbcheck"* ]]; then
            display_name="🔍 $(echo "$filename" | sed 's/-gateway.*/ - Database Check/')"
          fi

          echo "                <li><a href=\"../$relative_path\">$display_name</a></li>" >> $NAMESPACE_HTML
          found_commands=true
        done
        echo "            </ul>" >> $NAMESPACE_HTML
      fi

      # Hub commands
      hub_commands=$(find ${BASE_COLLECTION_PATH}/commands -name "*hub*" -name "*.log" -type f | sort)
      if [ -n "$hub_commands" ]; then
        echo "            <h3>🏪 Automation Hub Commands</h3>" >> $NAMESPACE_HTML
        echo "            <ul>" >> $NAMESPACE_HTML
        for cmdfile in $hub_commands; do
          filename=$(basename "$cmdfile")
          relative_path=$(echo "$cmdfile" | sed "s|${BASE_COLLECTION_PATH}/||")

          # Create descriptive display names
          display_name="$filename"
          if [[ "$filename" == *"showmigrations"* ]]; then
            display_name="📊 $(echo "$filename" | sed 's/-hub.*/ - Database Migrations/')"
          elif [[ "$filename" == *"status"* ]]; then
            display_name="📈 $(echo "$filename" | sed 's/-hub.*/ - Status Check/')"
          elif [[ "$filename" == *"version"* ]]; then
            display_name="🏷️ $(echo "$filename" | sed 's/-hub.*/ - Version Info/')"
          fi

          echo "                <li><a href=\"../$relative_path\">$display_name</a></li>" >> $NAMESPACE_HTML
          found_commands=true
        done
        echo "            </ul>" >> $NAMESPACE_HTML
      fi

      # EDA commands
      eda_commands=$(find ${BASE_COLLECTION_PATH}/commands -name "*eda*" -name "*.log" -type f | sort)
      if [ -n "$eda_commands" ]; then
        echo "            <h3>🔄 Event-Driven Automation Commands</h3>" >> $NAMESPACE_HTML
        echo "            <ul>" >> $NAMESPACE_HTML
        for cmdfile in $eda_commands; do
          filename=$(basename "$cmdfile")
          relative_path=$(echo "$cmdfile" | sed "s|${BASE_COLLECTION_PATH}/||")

          # Create descriptive display names
          display_name="$filename"
          if [[ "$filename" == *"showmigrations"* ]]; then
            display_name="📊 $(echo "$filename" | sed 's/-eda.*/ - Database Migrations/')"
          elif [[ "$filename" == *"version"* ]]; then
            display_name="🏷️ $(echo "$filename" | sed 's/-eda.*/ - Version Info/')"
          elif [[ "$filename" == *"dbcheck"* ]]; then
            display_name="🔍 $(echo "$filename" | sed 's/-eda.*/ - Database Check/')"
          fi

          echo "                <li><a href=\"../$relative_path\">$display_name</a></li>" >> $NAMESPACE_HTML
          found_commands=true
        done
        echo "            </ul>" >> $NAMESPACE_HTML
      fi
    fi

    if [ "$found_commands" = false ]; then
      echo "            <p><em>No management command outputs found for this namespace.</em></p>" >> $NAMESPACE_HTML
      echo "            <p><strong>Note:</strong> Management commands are collected from running AAP component pods. If no commands are shown, the components may not be running or accessible.</p>" >> $NAMESPACE_HTML
    fi

    echo "        </div>" >> $NAMESPACE_HTML

    # Add Config Files section
    echo "        <div class=\"section\">" >> $NAMESPACE_HTML
    echo "            <h2>⚙️ Configuration Files</h2>" >> $NAMESPACE_HTML
    echo "            <p>Configuration files collected from key AAP containers in this namespace:</p>" >> $NAMESPACE_HTML

    # Find config files related to this namespace
    found_configs=false
    if [ -d "${BASE_COLLECTION_PATH}/configs" ]; then

      # Group configs by component type
      # Gateway configs
      gateway_configs=$(find ${BASE_COLLECTION_PATH}/configs -name "*gateway*" -name "*.yml" -o -name "*gateway*" -name "*.conf" -type f | sort)
      if [ -n "$gateway_configs" ]; then
        echo "            <h3>🌐 AAP Gateway Configuration</h3>" >> $NAMESPACE_HTML
        echo "            <ul>" >> $NAMESPACE_HTML
        for configfile in $gateway_configs; do
          filename=$(basename "$configfile")
          relative_path=$(echo "$configfile" | sed "s|${BASE_COLLECTION_PATH}/||")

          # Create descriptive display names
          display_name="$filename"
          if [[ "$filename" == *"proxy.yml"* ]]; then
            display_name="🔧 $(echo "$filename" | sed 's/-api-proxy.yml/ - Gateway Proxy Configuration/')"
          elif [[ "$filename" == *"nginx.conf"* ]]; then
            display_name="🌐 $(echo "$filename" | sed 's/-proxy-nginx.conf/ - Nginx Configuration/')"
          elif [[ "$filename" == *"redis.conf"* ]]; then
            display_name="🗄️ $(echo "$filename" | sed 's/-redis.conf/ - Redis Configuration/')"
          fi

          echo "                <li><a href=\"../$relative_path\">$display_name</a></li>" >> $NAMESPACE_HTML
          found_configs=true
        done
        echo "            </ul>" >> $NAMESPACE_HTML
      fi

      # Controller configs
      controller_configs=$(find ${BASE_COLLECTION_PATH}/configs -name "*controller*" -name "*.conf" -o -name "*controller*" -name "*.py" -type f | sort)
      if [ -n "$controller_configs" ]; then
        echo "            <h3>🎮 Automation Controller Configuration</h3>" >> $NAMESPACE_HTML
        echo "            <ul>" >> $NAMESPACE_HTML
        for configfile in $controller_configs; do
          filename=$(basename "$configfile")
          relative_path=$(echo "$configfile" | sed "s|${BASE_COLLECTION_PATH}/||")

          # Create descriptive display names
          display_name="$filename"
          if [[ "$filename" == *"receptor.conf"* ]]; then
            display_name="📡 $(echo "$filename" | sed 's/-.*-receptor.conf/ - Receptor Configuration/')"
          elif [[ "$filename" == *"nginx.conf"* ]]; then
            display_name="🌐 $(echo "$filename" | sed 's/-.*-nginx.conf/ - Nginx Configuration/')"
          elif [[ "$filename" == *"redis.conf"* ]]; then
            display_name="🗄️ $(echo "$filename" | sed 's/-.*-redis.conf/ - Redis Configuration/')"
          elif [[ "$filename" == *"supervisord.conf"* ]]; then
            display_name="👥 $(echo "$filename" | sed 's/-.*-supervisord.conf/ - Supervisord Configuration/')"
          elif [[ "$filename" == *"tower_settings.py"* ]]; then
            display_name="⚙️ $(echo "$filename" | sed 's/-.*-tower_settings.py/ - Tower Settings/')"
          fi

          echo "                <li><a href=\"../$relative_path\">$display_name</a></li>" >> $NAMESPACE_HTML
          found_configs=true
        done
        echo "            </ul>" >> $NAMESPACE_HTML
      fi

      # Hub configs
      hub_configs=$(find ${BASE_COLLECTION_PATH}/configs -name "*hub*" -name "*.conf" -o -name "*hub*" -name "*.py" -type f | sort)
      if [ -n "$hub_configs" ]; then
        echo "            <h3>🏪 Automation Hub Configuration</h3>" >> $NAMESPACE_HTML
        echo "            <ul>" >> $NAMESPACE_HTML
        for configfile in $hub_configs; do
          filename=$(basename "$configfile")
          relative_path=$(echo "$configfile" | sed "s|${BASE_COLLECTION_PATH}/||")

          # Create descriptive display names
          display_name="$filename"
          if [[ "$filename" == *"nginx.conf"* ]]; then
            display_name="🌐 $(echo "$filename" | sed 's/-.*-nginx.conf/ - Nginx Configuration/')"
          elif [[ "$filename" == *"pulp_settings.py"* ]]; then
            display_name="📦 $(echo "$filename" | sed 's/-.*-pulp_settings.py/ - Pulp Settings/')"
          fi

          echo "                <li><a href=\"../$relative_path\">$display_name</a></li>" >> $NAMESPACE_HTML
          found_configs=true
        done
        echo "            </ul>" >> $NAMESPACE_HTML
      fi

      # EDA configs
      eda_configs=$(find ${BASE_COLLECTION_PATH}/configs -name "*eda*" -name "*.conf" -o -name "*eda*" -name "*.py" -type f | sort)
      if [ -n "$eda_configs" ]; then
        echo "            <h3>🔄 Event-Driven Automation Configuration</h3>" >> $NAMESPACE_HTML
        echo "            <ul>" >> $NAMESPACE_HTML
        for configfile in $eda_configs; do
          filename=$(basename "$configfile")
          relative_path=$(echo "$configfile" | sed "s|${BASE_COLLECTION_PATH}/||")

          # Create descriptive display names
          display_name="$filename"
          if [[ "$filename" == *"nginx.conf"* ]]; then
            display_name="🌐 $(echo "$filename" | sed 's/-.*-nginx.conf/ - Nginx Configuration/')"
          elif [[ "$filename" == *"eda_settings.py"* ]]; then
            display_name="⚡ $(echo "$filename" | sed 's/-.*-eda_settings.py/ - EDA Settings/')"
          fi

          echo "                <li><a href=\"../$relative_path\">$display_name</a></li>" >> $NAMESPACE_HTML
          found_configs=true
        done
        echo "            </ul>" >> $NAMESPACE_HTML
      fi

      # Redis standalone configs
      redis_configs=$(find ${BASE_COLLECTION_PATH}/configs -name "*redis*" -name "*.conf" -type f | grep -v controller | grep -v gateway | sort)
      if [ -n "$redis_configs" ]; then
        echo "            <h3>🗄️ Redis Configuration</h3>" >> $NAMESPACE_HTML
        echo "            <ul>" >> $NAMESPACE_HTML
        for configfile in $redis_configs; do
          filename=$(basename "$configfile")
          relative_path=$(echo "$configfile" | sed "s|${BASE_COLLECTION_PATH}/||")

          display_name="🗄️ $(echo "$filename" | sed 's/-redis.conf/ - Redis Configuration/')"

          echo "                <li><a href=\"../$relative_path\">$display_name</a></li>" >> $NAMESPACE_HTML
          found_configs=true
        done
        echo "            </ul>" >> $NAMESPACE_HTML
      fi
    fi

    if [ "$found_configs" = false ]; then
      echo "            <p><em>No configuration files found for this namespace.</em></p>" >> $NAMESPACE_HTML
      echo "            <p><strong>Note:</strong> Configuration files are collected from running AAP component pods. If no configs are shown, the components may not be running or accessible.</p>" >> $NAMESPACE_HTML
    fi

    echo "        </div>" >> $NAMESPACE_HTML

    # Add Raw Resources section
    echo "        <div class=\"section\">" >> $NAMESPACE_HTML
    echo "            <h2>🗂️ All Kubernetes Resources</h2>" >> $NAMESPACE_HTML
    echo "            <p>Complete resource dumps for this namespace:</p>" >> $NAMESPACE_HTML

    relative_ns_path=$(echo "$ns_dir" | sed "s|${BASE_COLLECTION_PATH}/||")
    echo "            <p><a href=\"../$relative_ns_path/\">📂 Browse All Resources for $namespace</a></p>" >> $NAMESPACE_HTML

    echo "        </div>" >> $NAMESPACE_HTML

    # Close the HTML
    cat >> $NAMESPACE_HTML << 'EOF'
    </div>
</body>
</html>
EOF

    echo "Generated namespace page: $NAMESPACE_HTML"
  done
}

