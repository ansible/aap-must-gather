      channel=$(grep "^  channel:" "$subscription_file" | awk '{print $2}' || echo "Unknown")
      source=$(grep "^  source:" "$subscription_file" | awk '{print $2}' || echo "Unknown")
      installed_csv=$(grep "^  installedCSV:" "$subscription_file" | awk '{print $2}' || echo "Unknown")

      echo "            <table>" >> $NAMESPACE_HTML
      echo "                <tr><th>Property</th><th>Value</th></tr>" >> $NAMESPACE_HTML
      echo "                <tr><td>Channel</td><td>$channel</td></tr>" >> $NAMESPACE_HTML
      echo "                <tr><td>Source</td><td>$source</td></tr>" >> $NAMESPACE_HTML
      echo "                <tr><td>Installed CSV</td><td>$installed_csv</td></tr>" >> $NAMESPACE_HTML
      echo "            </table>" >> $NAMESPACE_HTML

      relative_sub_path=$(echo "$subscription_file" | sed "s|${BASE_COLLECTION_PATH}/||")
      echo "            <p><a href=\"../$relative_sub_path\">📄 View Subscription Details</a></p>" >> $NAMESPACE_HTML
    else
      echo "            <p><em>No AAP operator subscription found in this namespace.</em></p>" >> $NAMESPACE_HTML
    fi

    echo "        </div>" >> $NAMESPACE_HTML

    # Add Pod Status section
    echo "        <div class=\"section\">" >> $NAMESPACE_HTML
    echo "            <h2>Pod Status</h2>" >> $NAMESPACE_HTML
    echo "            <p>Current status of all pods in this namespace (useful for identifying crashing pods):</p>" >> $NAMESPACE_HTML

    # Check for dedicated pod status file
    pod_status_file="${BASE_COLLECTION_PATH}/pod-status/${namespace}-pods.log"
    pod_info_found=false

    if [ -f "$pod_status_file" ]; then
      echo "            <h3>Pod Status Summary</h3>" >> $NAMESPACE_HTML
      echo "            <pre style=\"background-color: #f8f9fa; padding: 10px; border-radius: 4px; overflow-x: auto; font-family: 'Courier New', monospace; font-size: 12px; white-space: pre;\">" >> $NAMESPACE_HTML

      # Read the pod status file and display it with proper column alignment
      pod_content=$(cat "$pod_status_file" 2>/dev/null)
      if [ -n "$pod_content" ] && [ "$pod_content" != "No pods found in namespace $namespace" ]; then
        # Use column command to align the output properly
        echo "$pod_content" | column -t >> $NAMESPACE_HTML
        pod_info_found=true
      else
        echo "No pods found in namespace: $namespace" >> $NAMESPACE_HTML
      fi

      echo "            </pre>" >> $NAMESPACE_HTML

      # Add link to the raw pod status file
      relative_pod_path=$(echo "$pod_status_file" | sed "s|${BASE_COLLECTION_PATH}/||")
      echo "            <p><a href=\"../$relative_pod_path\">📄 View raw pod status file</a></p>" >> $NAMESPACE_HTML
    fi

    if [ "$pod_info_found" = false ]; then
      echo "            <p><em>No pod information found for this namespace in the collected data.</em></p>" >> $NAMESPACE_HTML
      echo "            <p><strong>Note:</strong> To see current pod status, run: <code>oc get pods -n $namespace</code></p>" >> $NAMESPACE_HTML
    fi

    echo "        </div>" >> $NAMESPACE_HTML

    # Add Logs section
    echo "        <div class=\"section\">" >> $NAMESPACE_HTML
    echo "            <h2>Logs</h2>" >> $NAMESPACE_HTML

    # Get the list of pods in this namespace from the pod status file
    pod_status_file="${BASE_COLLECTION_PATH}/pod-status/${namespace}-pods.log"
    namespace_pods=""
    if [ -f "$pod_status_file" ]; then
      # Extract pod names from the pod status file (skip header line)
      namespace_pods=$(tail -n +2 "$pod_status_file" | awk '{print $1}' | grep -v '^$')
    fi

    # Find operator logs first (these are most important for troubleshooting)
    found_operator_logs=false
    if [ -d "${BASE_COLLECTION_PATH}/logs" ] && [ -n "$namespace_pods" ]; then
      # Build a list of operator logs for pods in this namespace
      operator_logs=""
      for pod in $namespace_pods; do
        # Find logs for this specific pod that contain "operator" in the filename
        pod_operator_logs=$(find ${BASE_COLLECTION_PATH}/logs -maxdepth 1 -name "${pod}-*operator*.log" -type f 2>/dev/null)
        if [ -n "$pod_operator_logs" ]; then
          operator_logs="$operator_logs $pod_operator_logs"
        fi
      done

      if [ -n "$operator_logs" ]; then
        echo "            <h3>Operator Pod Logs</h3>" >> $NAMESPACE_HTML
        echo "            <p>Latest logs from AAP operator pods (most useful for troubleshooting operator issues):</p>" >> $NAMESPACE_HTML
        echo "            <ul>" >> $NAMESPACE_HTML

        for logfile in $(echo $operator_logs | tr ' ' '\n' | sort); do
          filename=$(basename "$logfile")
          relative_path=$(echo "$logfile" | sed "s|${BASE_COLLECTION_PATH}/||")

          # Create a more readable display name for operator logs
          display_name="$filename"
          if [[ "$filename" == *"operator-controller-manager"* ]]; then
            # Extract operator type (e.g., "aap-gateway", "automation-controller", etc.)
            operator_type=$(echo "$filename" | sed -E 's/^(.*)-operator-controller-manager.*/\1/')

            # Extract container name by removing prefix and suffix
            # Pattern: {operator-type}-operator-controller-manager-{pod-hash}-{container-name}-operator[-previous].log
            temp=$(echo "$filename" | sed -E 's/^.*-operator-controller-manager-//')
            # Remove pod hash (format: {hash1}-{hash2}-)
            temp2=$(echo "$temp" | sed -E 's/^[a-z0-9]+-[a-z0-9]+-//')
            # Remove -operator[-previous].log suffix
            container_name=$(echo "$temp2" | sed -E 's/-operator(-previous)?\.log$//')

            # Determine if this is current or previous log
            if [[ "$filename" == *"previous"* ]]; then
              log_type="Previous"
            else
              log_type="Current"
            fi

            # Format the display name
            display_name="$operator_type - $container_name ($log_type)"
          fi

          echo "                <li><a href=\"../$relative_path\">$display_name</a></li>" >> $NAMESPACE_HTML
          found_operator_logs=true
        done
        echo "            </ul>" >> $NAMESPACE_HTML
      fi
    fi

    # Find pod container and initContainer logs
    found_container_logs=false
    if [ -d "${BASE_COLLECTION_PATH}/logs" ] && [ -n "$namespace_pods" ]; then
      # Build a list of container logs for pods in this namespace
      container_logs=""
      for pod in $namespace_pods; do
        # Find logs for this specific pod that don't contain "operator" in the filename
        pod_container_logs=$(find ${BASE_COLLECTION_PATH}/logs -maxdepth 1 -name "${pod}-*.log" -type f 2>/dev/null | grep -v operator)
        if [ -n "$pod_container_logs" ]; then
          container_logs="$container_logs $pod_container_logs"
        fi
      done

      if [ -n "$container_logs" ]; then
        echo "            <h3>Pod Container Logs</h3>" >> $NAMESPACE_HTML
        echo "            <p>Logs from pod containers and initContainers in this namespace:</p>" >> $NAMESPACE_HTML
        echo "            <ul>" >> $NAMESPACE_HTML

        for logfile in $(echo $container_logs | tr ' ' '\n' | sort); do
          filename=$(basename "$logfile")
          relative_path=$(echo "$logfile" | sed "s|${BASE_COLLECTION_PATH}/||")

          # Create more descriptive display names for container logs
          display_name="$filename"
          if [[ "$filename" == *"init"* ]]; then
            display_name="$filename (initContainer)"
          elif [[ "$filename" == *"container"* ]]; then
            display_name="$filename (container)"
          else
            display_name="$filename"
          fi

          echo "                <li><a href=\"../$relative_path\">$display_name</a></li>" >> $NAMESPACE_HTML
          found_container_logs=true
        done
        echo "            </ul>" >> $NAMESPACE_HTML
      fi
    fi

    if [ "$found_operator_logs" = false ] && [ "$found_container_logs" = false ]; then
      echo "            <p><em>No logs found for this namespace.</em></p>" >> $NAMESPACE_HTML
    fi

    echo "        </div>" >> $NAMESPACE_HTML

    # Add Commands section
    echo "        <div class=\"section\">" >> $NAMESPACE_HTML
    echo "            <h2>Management Command Outputs</h2>" >> $NAMESPACE_HTML
