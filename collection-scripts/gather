      echo "                <li><a href=\"namespaces-html/$namespace.html\">📁 $namespace</a> - Complete resources and logs for this namespace</li>" >> $INDEX_FILE
    done
  else
    echo "                <li><em>No namespace detail pages generated.</em></li>" >> $INDEX_FILE
  fi

  cat >> $INDEX_FILE << 'EOF'
            </ul>
        </div>

