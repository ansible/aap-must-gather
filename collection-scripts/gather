                    <th>AAP</th>
                    <th>Controller</th>
                    <th>Hub</th>
                    <th>EDA</th>
                    <th>Lightspeed</th>
                </tr>
EOF

    # Process each operator installation
    while IFS='|' read namespace channel scope csv_version csv_display_name aap_count controller_count hub_count eda_count lightspeed_count; do
      scope_class=""
      if [ "$scope" = "Cluster-scoped" ]; then
        scope_class="cluster-scoped"
      else
        scope_class="namespace-scoped"
      fi

      echo "                <tr class=\"$scope_class\">" >> $INDEX_FILE
      echo "                    <td><strong>$namespace</strong></td>" >> $INDEX_FILE
      echo "                    <td>$channel</td>" >> $INDEX_FILE
      echo "                    <td>$scope</td>" >> $INDEX_FILE
      echo "                    <td>$csv_version</td>" >> $INDEX_FILE
      echo "                    <td>$aap_count</td>" >> $INDEX_FILE
      echo "                    <td>$controller_count</td>" >> $INDEX_FILE
      echo "                    <td>$hub_count</td>" >> $INDEX_FILE
      echo "                    <td>$eda_count</td>" >> $INDEX_FILE
      echo "                    <td>$lightspeed_count</td>" >> $INDEX_FILE
      echo "                </tr>" >> $INDEX_FILE
    done < "$OPERATOR_SUMMARY_FILE"

    cat >> $INDEX_FILE << 'EOF'
            </table>
            <p><em>Scope is determined by the operator channel. Numbers indicate count of custom resources of each type.</em></p>
EOF
  else
    cat >> $INDEX_FILE << 'EOF'
            <p><em>No AAP operator installations found in the collected data.</em></p>
EOF
  fi

  # Clean up temporary file
  rm -f "$OPERATOR_SUMMARY_FILE"

  cat >> $INDEX_FILE << 'EOF'
        </div>

        <div class="section" id="namespaces">
            <h2>📁 Namespace Details</h2>
            <p>Detailed information for each namespace with AAP components:</p>
            <ul>
EOF

