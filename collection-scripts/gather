# ============================================================================
# Helper Function: Execute Management Command
# ============================================================================
# Usage: exec_management_command <pod> <namespace> <container> <command_spec>
# Command spec format: "command:subcommand:output_filename"
exec_management_command() {
  local pod=$1
  local namespace=$2
  local container=$3
  local command_spec=$4

  # Parse command spec (format: "command:subcommand:filename")
  local cmd_base=$(echo "$command_spec" | cut -d':' -f1)
  local cmd_args=$(echo "$command_spec" | cut -d':' -f2)
  local output_file=$(echo "$command_spec" | cut -d':' -f3)

  local full_command="$cmd_base $cmd_args"
  local output_path="${BASE_COLLECTION_PATH}/commands/${pod}-${output_file}"

  # Execute command and capture output
  oc exec $pod -n $namespace -c $container -- $full_command > "$output_path" 2>/dev/null

  if [ $? -eq 0 ]; then
    echo "  ✓ Collected: $cmd_base $cmd_args" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  else
    echo "  ✗ Failed: $cmd_base $cmd_args from $pod (container: $container)" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
    # Create empty file to indicate attempt was made
    echo "Command failed or not available" > "$output_path"
  fi
}

# ============================================================================
# Helper Function: Execute Commands for Pod
# ============================================================================
# Usage: exec_commands_for_pod <pod> <namespace> <container> <commands_array_name>
exec_commands_for_pod() {
  local pod=$1
  local namespace=$2
  local container=$3
  local commands_array_name=$4

  # Get array reference
  local -n commands_array=$commands_array_name

  echo "Collecting ${#commands_array[@]} commands from pod: $pod (container: $container)"

  # Loop through all commands
  for command_spec in "${commands_array[@]}"; do
    exec_management_command "$pod" "$namespace" "$container" "$command_spec"
  done
}

