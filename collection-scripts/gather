#!/bin/bash

# Set BASE_COLLECTION_PATH if not already set by must-gather framework
if [ -z "$BASE_COLLECTION_PATH" ]; then
  BASE_COLLECTION_PATH="/must-gather"
fi
mkdir -p ${BASE_COLLECTION_PATH}
mkdir -p ${BASE_COLLECTION_PATH}/logs
mkdir -p ${BASE_COLLECTION_PATH}/commands
mkdir -p ${BASE_COLLECTION_PATH}/reports

ANSIBLECRD="automationcontrollerbackups.automationcontroller.ansible.com \
  automationcontrollerrestores.automationcontroller.ansible.com \
  automationcontrollers.automationcontroller.ansible.com \
  automationcontrollermeshingresses.automationcontroller.ansible.com \
  automationhubbackups.automationhub.ansible.com \
  automationhubrestores.automationhub.ansible.com \
  automationhubs.automationhub.ansible.com \
  edas.eda.ansible.com \
  edabackups.eda.ansible.com \
  edarestores.eda.ansible.com \
  ansiblecredentials.tower.ansible.com \
  ansibleinstancegroups.tower.ansible.com \
  ansibleinventories.tower.ansible.com \
  ansibleprojects.tower.ansible.com \
  ansibleschedules.tower.ansible.com \
  ansiblejobs.tower.ansible.com \
  ansibleworkflows.tower.ansible.com \
  jobtemplates.tower.ansible.com \
  workflowtemplates.tower.ansible.com \
  ansiblelightspeeds.lightspeed.ansible.com \
  ansibleautomationplatforms.aap.ansible.com \
  ansibleautomationplatformbackups.aap.ansible.com \
  ansibleautomationplatformrestores.aap.ansible.com"

# Collect cluster version information
echo "Collecting cluster version information..."
oc adm inspect clusterversion --dest-dir=${BASE_COLLECTION_PATH}/must-gather

oc adm inspect customresourcedefinition.apiextensions.k8s.io $ANSIBLECRD --dest-dir=${BASE_COLLECTION_PATH}/must-gather
oc adm inspect customresourcedefinition.apiextensions.k8s.io subscriptions.operators.coreos.com clusterserviceversions.operators.coreos.com --dest-dir=${BASE_COLLECTION_PATH}/must-gather

for i in $ANSIBLECRD; do
   oc adm inspect $i --all-namespaces --dest-dir=${BASE_COLLECTION_PATH}/must-gather
   ANSIBLENS+=`oc get $i --all-namespaces --no-headers=true -o custom-columns=NAMESPACE:.metadata.namespace; echo " "`
done

NS=`echo ${ANSIBLENS[@]} | xargs -n1 | sort -u`

for a in $NS; do
  oc adm inspect ns/"$a"  --dest-dir=must-gather
  oc adm inspect -n $a csv --dest-dir=must-gather

  # Collect pod status for this namespace
  echo "Collecting pod status for namespace: $a"
  echo "========================================" >> ${BASE_COLLECTION_PATH}/gather-aap.log
  echo "NAMESPACE: $a - Pod Status" >> ${BASE_COLLECTION_PATH}/gather-aap.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/gather-aap.log
  oc get pods -n $a >> ${BASE_COLLECTION_PATH}/gather-aap.log

  # Also create a dedicated pod status file for this namespace
  mkdir -p "${BASE_COLLECTION_PATH}/pod-status"
  oc get pods -n $a -o wide > "${BASE_COLLECTION_PATH}/pod-status/${a}-pods.log" 2>/dev/null || echo "No pods found in namespace $a" > "${BASE_COLLECTION_PATH}/pod-status/${a}-pods.log"

  # Collect PVC status and common resources for each namespace
  echo "Collecting PVC status and common resources for namespace: $a"

  # PVC status with namespace header
  echo "" >> ${BASE_COLLECTION_PATH}/pvc-status.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/pvc-status.log
  echo "NAMESPACE: $a" >> ${BASE_COLLECTION_PATH}/pvc-status.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/pvc-status.log
  oc get pvc -n $a -o wide >> ${BASE_COLLECTION_PATH}/pvc-status.log 2>/dev/null || echo "No PVCs found in namespace $a" >> ${BASE_COLLECTION_PATH}/pvc-status.log

  # Deployments with namespace header
  echo "" >> ${BASE_COLLECTION_PATH}/deployments.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/deployments.log
  echo "NAMESPACE: $a" >> ${BASE_COLLECTION_PATH}/deployments.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/deployments.log
  oc get deployments -n $a -o wide >> ${BASE_COLLECTION_PATH}/deployments.log 2>/dev/null || echo "No deployments found in namespace $a" >> ${BASE_COLLECTION_PATH}/deployments.log

  # Services with namespace header
  echo "" >> ${BASE_COLLECTION_PATH}/services.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/services.log
  echo "NAMESPACE: $a" >> ${BASE_COLLECTION_PATH}/services.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/services.log
  oc get services -n $a -o wide >> ${BASE_COLLECTION_PATH}/services.log 2>/dev/null || echo "No services found in namespace $a" >> ${BASE_COLLECTION_PATH}/services.log

  # ConfigMaps with namespace header
  echo "" >> ${BASE_COLLECTION_PATH}/configmaps.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/configmaps.log
  echo "NAMESPACE: $a" >> ${BASE_COLLECTION_PATH}/configmaps.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/configmaps.log
  oc get configmaps -n $a -o wide >> ${BASE_COLLECTION_PATH}/configmaps.log 2>/dev/null || echo "No configmaps found in namespace $a" >> ${BASE_COLLECTION_PATH}/configmaps.log

  # Secrets with namespace header
  echo "" >> ${BASE_COLLECTION_PATH}/secrets.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/secrets.log
  echo "NAMESPACE: $a" >> ${BASE_COLLECTION_PATH}/secrets.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/secrets.log
  oc get secrets -n $a -o wide >> ${BASE_COLLECTION_PATH}/secrets.log 2>/dev/null || echo "No secrets found in namespace $a" >> ${BASE_COLLECTION_PATH}/secrets.log

  # Routes with namespace header
  echo "" >> ${BASE_COLLECTION_PATH}/routes.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/routes.log
  echo "NAMESPACE: $a" >> ${BASE_COLLECTION_PATH}/routes.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/routes.log
  oc get routes -n $a -o wide >> ${BASE_COLLECTION_PATH}/routes.log 2>/dev/null || echo "No routes found in namespace $a" >> ${BASE_COLLECTION_PATH}/routes.log

  # Ingress with namespace header
  echo "" >> ${BASE_COLLECTION_PATH}/ingress.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/ingress.log
  echo "NAMESPACE: $a" >> ${BASE_COLLECTION_PATH}/ingress.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/ingress.log
  oc get ingress -n $a -o wide >> ${BASE_COLLECTION_PATH}/ingress.log 2>/dev/null || echo "No ingress found in namespace $a" >> ${BASE_COLLECTION_PATH}/ingress.log
done

for b in $(oc get -A subs --field-selector='metadata.name=ansible-automation-platform-operator' -o custom-columns=NAMESPACE:.metadata.namespace); do
  oc adm inspect ns/"$b" --dest-dir=must-gather

  # Collect pod status for operator namespace
  echo "========================================" >> ${BASE_COLLECTION_PATH}/gather-aap.log
  echo "NAMESPACE: $b - Pod Status (Operator)" >> ${BASE_COLLECTION_PATH}/gather-aap.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/gather-aap.log
  oc get pods -n $b >> ${BASE_COLLECTION_PATH}/gather-aap.log

  # Create/update dedicated pod status file for this namespace
  mkdir -p "${BASE_COLLECTION_PATH}/pod-status"
  oc get pods -n $b -o wide > "${BASE_COLLECTION_PATH}/pod-status/${b}-pods.log" 2>/dev/null || echo "No pods found in namespace $b" > "${BASE_COLLECTION_PATH}/pod-status/${b}-pods.log"

  oc adm inspect -n $b subs --dest-dir=must-gather
done

# Function to collect initContainer logs
collect_init_container_logs() {
  local namespace=$1
  echo "Collecting initContainer logs for namespace: $namespace"

  # Get all pods in the namespace
  for pod in $(oc get pods -n $namespace -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    # Check if pod has initContainers
    init_containers=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.initContainers[*].name}' 2>/dev/null)
    if [ ! -z "$init_containers" ]; then
      echo "Found initContainers in pod $pod: $init_containers"
      for init_container in $init_containers; do
        echo "Collecting logs for initContainer: $init_container in pod: $pod"
        oc logs $pod -n $namespace -c $init_container > "${BASE_COLLECTION_PATH}/logs/${pod}-${init_container}-init.log" 2>/dev/null || echo "Failed to collect logs for initContainer $init_container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      done
    fi
  done
}

# Function to collect migration job logs
collect_migration_job_logs() {
  local namespace=$1
  echo "Collecting migration job logs for namespace: $namespace"

  # Collect logs from controller migration jobs
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=automationcontroller --field-selector=status.phase=Succeeded -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    # Check if this is a migration job pod
    if [[ "$pod" == *"migration"* ]]; then
      echo "Found controller migration job pod: $pod"
      # Get the container name for the migration job
      migration_container=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[0].name}' 2>/dev/null)
      if [ ! -z "$migration_container" ]; then
        echo "Collecting logs for migration job container: $migration_container in pod: $pod"
        oc logs $pod -n $namespace -c $migration_container > "${BASE_COLLECTION_PATH}/logs/${pod}-${migration_container}.log" 2>/dev/null || echo "Failed to collect logs for migration job $migration_container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      fi
    fi
  done

  # Also collect logs from any running or failed migration jobs
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=automationcontroller --field-selector=status.phase=Failed -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    if [[ "$pod" == *"migration"* ]]; then
      echo "Found failed controller migration job pod: $pod"
      migration_container=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[0].name}' 2>/dev/null)
      if [ ! -z "$migration_container" ]; then
        echo "Collecting logs for failed migration job container: $migration_container in pod: $pod"
        oc logs $pod -n $namespace -c $migration_container > "${BASE_COLLECTION_PATH}/logs/${pod}-${migration_container}.log" 2>/dev/null || echo "Failed to collect logs for failed migration job $migration_container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      fi
    fi
  done

  # Collect logs from gateway migration jobs
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/name=automation-platform-gateway --field-selector=status.phase=Succeeded -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    if [[ "$pod" == *"migration"* ]]; then
      echo "Found gateway migration job pod: $pod"
      migration_container=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[0].name}' 2>/dev/null)
      if [ ! -z "$migration_container" ]; then
        echo "Collecting logs for gateway migration job container: $migration_container in pod: $pod"
        oc logs $pod -n $namespace -c $migration_container > "${BASE_COLLECTION_PATH}/logs/${pod}-${migration_container}.log" 2>/dev/null || echo "Failed to collect logs for gateway migration job $migration_container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      fi
    fi
  done

  # Collect logs from EDA migration jobs
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=eda --field-selector=status.phase=Succeeded -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    if [[ "$pod" == *"migration"* ]]; then
      echo "Found EDA migration job pod: $pod"
      migration_container=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[0].name}' 2>/dev/null)
      if [ ! -z "$migration_container" ]; then
        echo "Collecting logs for EDA migration job container: $migration_container in pod: $pod"
        oc logs $pod -n $namespace -c $migration_container > "${BASE_COLLECTION_PATH}/logs/${pod}-${migration_container}.log" 2>/dev/null || echo "Failed to collect logs for EDA migration job $migration_container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      fi
    fi
  done
}

# Function to collect operator pod logs
collect_operator_logs() {
  local namespace=$1
  echo "Collecting operator pod logs for namespace: $namespace"

  # Collect logs from AAP operator pods
  for pod in $(oc get pods -n $namespace -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    # Check if this is an operator pod
    if [[ "$pod" == *"operator-controller-manager"* ]]; then
      echo "Found operator pod: $pod"

      # Get all containers in the operator pod
      containers=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[*].name}' 2>/dev/null)
      if [ ! -z "$containers" ]; then
        for container in $containers; do
          echo "Collecting logs for operator container: $container in pod: $pod"
          oc logs $pod -n $namespace -c $container > "${BASE_COLLECTION_PATH}/logs/${pod}-${container}-operator.log" 2>/dev/null || echo "Failed to collect logs for operator container $container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
        done
      fi

      # Also collect previous logs if available (useful for crashed operators)
      for container in $containers; do
        echo "Collecting previous logs for operator container: $container in pod: $pod"
        oc logs $pod -n $namespace -c $container --previous > "${BASE_COLLECTION_PATH}/logs/${pod}-${container}-operator-previous.log" 2>/dev/null || echo "No previous logs available for operator container $container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      done
    fi
  done
}

# Function to collect configuration files from key containers
collect_config_files() {
  local namespace=$1
  echo "Collecting configuration files from key containers for namespace: $namespace"

  # Create config directory
  mkdir -p "${BASE_COLLECTION_PATH}/configs"

  # Gateway-api pods - collect proxy.yml, nginx.conf, redis.conf
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=aap-gateway -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting config files from gateway pod: $pod"

    # Collect proxy.yml from api container
    oc exec $pod -n $namespace -c api -- cat /etc/ansible-automation-platform/gateway/proxy.yml > "${BASE_COLLECTION_PATH}/configs/${pod}-api-proxy.yml" 2>/dev/null || echo "Failed to collect proxy.yml from gateway $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # Collect nginx.conf from proxy container
    oc exec $pod -n $namespace -c proxy -- cat /etc/nginx/nginx.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-proxy-nginx.conf" 2>/dev/null || echo "Failed to collect nginx.conf from gateway $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # Collect redis.conf if redis container exists
    oc exec $pod -n $namespace -c redis -- cat /etc/redis/redis.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-redis.conf" 2>/dev/null || echo "No redis container or redis.conf in gateway $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  done

  # Controller-web pods - collect receptor.conf, redis.conf, nginx.conf, supervisord.conf, tower_settings.py
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=automationcontroller -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    # Check if this is a web pod (not task pod)
    if [[ "$pod" == *"web"* ]]; then
      echo "Collecting config files from controller web pod: $pod"

      # Collect receptor.conf
      oc exec $pod -n $namespace -c myaap-controller-web -- cat /etc/receptor/receptor.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-web-receptor.conf" 2>/dev/null || echo "Failed to collect receptor.conf from controller web $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

      # Collect redis.conf from redis container
      oc exec $pod -n $namespace -c redis -- cat /etc/redis/redis.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-web-redis.conf" 2>/dev/null || echo "Failed to collect redis.conf from controller web $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

      # Collect nginx.conf
      oc exec $pod -n $namespace -c myaap-controller-web -- cat /etc/nginx/nginx.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-web-nginx.conf" 2>/dev/null || echo "Failed to collect nginx.conf from controller web $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

      # Collect supervisord.conf
      oc exec $pod -n $namespace -c myaap-controller-web -- cat /etc/supervisord.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-web-supervisord.conf" 2>/dev/null || echo "Failed to collect supervisord.conf from controller web $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

      # Collect tower_settings.py
      oc exec $pod -n $namespace -c myaap-controller-web -- cat /etc/tower/settings.py > "${BASE_COLLECTION_PATH}/configs/${pod}-web-tower_settings.py" 2>/dev/null || \
      oc exec $pod -n $namespace -c myaap-controller-web -- cat /etc/tower/tower_settings.py > "${BASE_COLLECTION_PATH}/configs/${pod}-web-tower_settings.py" 2>/dev/null || \
      echo "Failed to collect tower_settings.py from controller web $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
    fi
  done

  # Controller-task pods - collect receptor.conf, redis.conf, supervisord.conf, tower_settings.py
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=task -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting config files from controller task pod: $pod"

    # Collect receptor.conf
    oc exec $pod -n $namespace -c automation-controller-task -- cat /etc/receptor/receptor.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-task-receptor.conf" 2>/dev/null || echo "Failed to collect receptor.conf from controller task $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # Collect redis.conf from redis container
    oc exec $pod -n $namespace -c redis -- cat /etc/redis/redis.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-task-redis.conf" 2>/dev/null || echo "Failed to collect redis.conf from controller task $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # Collect supervisord.conf
    oc exec $pod -n $namespace -c automation-controller-task -- cat /etc/supervisord.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-task-supervisord.conf" 2>/dev/null || echo "Failed to collect supervisord.conf from controller task $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # Collect tower_settings.py
    oc exec $pod -n $namespace -c automation-controller-task -- cat /etc/tower/settings.py > "${BASE_COLLECTION_PATH}/configs/${pod}-task-tower_settings.py" 2>/dev/null || \
    oc exec $pod -n $namespace -c automation-controller-task -- cat /etc/tower/tower_settings.py > "${BASE_COLLECTION_PATH}/configs/${pod}-task-tower_settings.py" 2>/dev/null || \
    echo "Failed to collect tower_settings.py from controller task $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  done

  # Hub API pods - collect nginx.conf, redis.conf, pulp settings
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/name=automationhub-api -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting config files from hub API pod: $pod"

    # Collect nginx.conf
    oc exec $pod -n $namespace -c api -- cat /etc/nginx/nginx.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-api-nginx.conf" 2>/dev/null || echo "Failed to collect nginx.conf from hub API $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # Collect pulp settings
    oc exec $pod -n $namespace -c api -- cat /etc/pulp/settings.py > "${BASE_COLLECTION_PATH}/configs/${pod}-api-pulp_settings.py" 2>/dev/null || echo "Failed to collect pulp settings from hub API $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  done

  # EDA API pods - collect nginx.conf, redis.conf, eda settings
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=eda-api -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting config files from EDA API pod: $pod"

    # Collect nginx.conf
    oc exec $pod -n $namespace -c nginx -- cat /etc/nginx/nginx.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-api-nginx.conf" 2>/dev/null || echo "Failed to collect nginx.conf from EDA API $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # Collect EDA settings
    oc exec $pod -n $namespace -c eda-api -- cat /etc/eda/settings.py > "${BASE_COLLECTION_PATH}/configs/${pod}-api-eda_settings.py" 2>/dev/null || echo "Failed to collect EDA settings from EDA API $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  done

  # Redis standalone pods - collect redis.conf
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/name=redis -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting config files from Redis pod: $pod"

    # Collect redis.conf
    oc exec $pod -n $namespace -c redis -- cat /etc/redis/redis.conf > "${BASE_COLLECTION_PATH}/configs/${pod}-redis.conf" 2>/dev/null || echo "Failed to collect redis.conf from Redis $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  done
}

# Function to collect comprehensive management commands output
collect_management_commands() {
  local namespace=$1
  echo "Collecting management commands output for namespace: $namespace"

  # Collect from automation controller task pods
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=task -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting management commands from controller task pod: $pod"

    # showmigrations
    oc exec $pod -n $namespace -c automation-controller-task -- awx-manage showmigrations > "${BASE_COLLECTION_PATH}/commands/${pod}-awx-task-showmigrations.log" 2>/dev/null || echo "Failed to collect showmigrations from task $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # version info
    oc exec $pod -n $namespace -c automation-controller-task -- awx-manage version > "${BASE_COLLECTION_PATH}/commands/${pod}-awx-task-version.log" 2>/dev/null || echo "Failed to collect version from task $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # check database connectivity
    oc exec $pod -n $namespace -c automation-controller-task -- awx-manage check --database default > "${BASE_COLLECTION_PATH}/commands/${pod}-awx-task-dbcheck.log" 2>/dev/null || echo "Failed to collect database check from task $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # Note: list_settings command removed to avoid exposing sensitive configuration data
  done

  # Collect from automation controller web pods
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=automationcontroller -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    # Check if this is a web pod (not task pod)
    if [[ "$pod" == *"web"* ]]; then
      echo "Collecting management commands from controller web pod: $pod"

      # showmigrations
      oc exec $pod -n $namespace -c myaap-controller-web -- awx-manage showmigrations > "${BASE_COLLECTION_PATH}/commands/${pod}-awx-web-showmigrations.log" 2>/dev/null || echo "Failed to collect showmigrations from web $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

      # version info
      oc exec $pod -n $namespace -c myaap-controller-web -- awx-manage version > "${BASE_COLLECTION_PATH}/commands/${pod}-awx-web-version.log" 2>/dev/null || echo "Failed to collect version from web $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
    fi
  done

  # Collect from gateway pods
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=aap-gateway -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting management commands from gateway pod: $pod"

    # showmigrations
    oc exec $pod -n $namespace -c api -- aap-gateway-manage showmigrations > "${BASE_COLLECTION_PATH}/commands/${pod}-gateway-showmigrations.log" 2>/dev/null || echo "Failed to collect showmigrations from gateway $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # version info
    oc exec $pod -n $namespace -c api -- aap-gateway-manage version > "${BASE_COLLECTION_PATH}/commands/${pod}-gateway-version.log" 2>/dev/null || echo "Failed to collect version from gateway $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # check database connectivity
    oc exec $pod -n $namespace -c api -- aap-gateway-manage check --database default > "${BASE_COLLECTION_PATH}/commands/${pod}-gateway-dbcheck.log" 2>/dev/null || echo "Failed to collect database check from gateway $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  done

  # Collect from automation hub API pods
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/name=automationhub-api -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting management commands from hub API pod: $pod"

    # showmigrations
    oc exec $pod -n $namespace -c api -- pulpcore-manage showmigrations > "${BASE_COLLECTION_PATH}/commands/${pod}-hub-showmigrations.log" 2>/dev/null || \
    oc exec $pod -n $namespace -c api -- python -m pulpcore.app.manage showmigrations > "${BASE_COLLECTION_PATH}/commands/${pod}-hub-showmigrations.log" 2>/dev/null || \
    echo "Failed to collect showmigrations from hub $pod - management command not available" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # status check
    oc exec $pod -n $namespace -c api -- pulpcore-manage status > "${BASE_COLLECTION_PATH}/commands/${pod}-hub-status.log" 2>/dev/null || \
    oc exec $pod -n $namespace -c api -- python -m pulpcore.app.manage status > "${BASE_COLLECTION_PATH}/commands/${pod}-hub-status.log" 2>/dev/null || \
    echo "Failed to collect status from hub $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # version info
    oc exec $pod -n $namespace -c api -- pulpcore-manage version > "${BASE_COLLECTION_PATH}/commands/${pod}-hub-version.log" 2>/dev/null || \
    oc exec $pod -n $namespace -c api -- python -m pulpcore.app.manage version > "${BASE_COLLECTION_PATH}/commands/${pod}-hub-version.log" 2>/dev/null || \
    echo "Failed to collect version from hub $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  done

  # Collect from EDA pods
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=eda-api -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting management commands from EDA pod: $pod"

    # showmigrations
    oc exec $pod -n $namespace -c eda-api -- aap-eda-manage showmigrations > "${BASE_COLLECTION_PATH}/commands/${pod}-eda-showmigrations.log" 2>/dev/null || echo "Failed to collect showmigrations from EDA $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # version info
    oc exec $pod -n $namespace -c eda-api -- aap-eda-manage version > "${BASE_COLLECTION_PATH}/commands/${pod}-eda-version.log" 2>/dev/null || echo "Failed to collect version from EDA $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"

    # check database connectivity
    oc exec $pod -n $namespace -c eda-api -- aap-eda-manage check --database default > "${BASE_COLLECTION_PATH}/commands/${pod}-eda-dbcheck.log" 2>/dev/null || echo "Failed to collect database check from EDA $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  done
}

# Call functions for each AAP namespace
