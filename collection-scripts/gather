#!/bin/bash

# Set BASE_COLLECTION_PATH if not already set by must-gather framework
if [ -z "$BASE_COLLECTION_PATH" ]; then
  BASE_COLLECTION_PATH="/must-gather"
fi
mkdir -p ${BASE_COLLECTION_PATH}
mkdir -p ${BASE_COLLECTION_PATH}/logs
mkdir -p ${BASE_COLLECTION_PATH}/commands
mkdir -p ${BASE_COLLECTION_PATH}/reports

ANSIBLECRD="automationcontrollerbackups.automationcontroller.ansible.com \
  automationcontrollerrestores.automationcontroller.ansible.com \
  automationcontrollers.automationcontroller.ansible.com \
  automationcontrollermeshingresses.automationcontroller.ansible.com \
  automationhubbackups.automationhub.ansible.com \
  automationhubrestores.automationhub.ansible.com \
  automationhubs.automationhub.ansible.com \
  edas.eda.ansible.com \
  edabackups.eda.ansible.com \
  edarestores.eda.ansible.com \
  ansiblecredentials.tower.ansible.com \
  ansibleinstancegroups.tower.ansible.com \
  ansibleinventories.tower.ansible.com \
  ansibleprojects.tower.ansible.com \
  ansibleschedules.tower.ansible.com \
  ansiblejobs.tower.ansible.com \
  ansibleworkflows.tower.ansible.com \
  jobtemplates.tower.ansible.com \
  workflowtemplates.tower.ansible.com \
  ansiblelightspeeds.lightspeed.ansible.com \
  ansibleautomationplatforms.aap.ansible.com \
  ansibleautomationplatformbackups.aap.ansible.com \
  ansibleautomationplatformrestores.aap.ansible.com"

# Collect cluster version information
echo "Collecting cluster version information..."
oc adm inspect clusterversion --dest-dir=must-gather

oc adm inspect customresourcedefinition.apiextensions.k8s.io $ANSIBLECRD --dest-dir=must-gather
oc adm inspect customresourcedefinition.apiextensions.k8s.io subscriptions.operators.coreos.com clusterserviceversions.operators.coreos.com --dest-dir=must-gather

for i in $ANSIBLECRD; do
   oc adm inspect $i --all-namespaces --dest-dir=must-gather 
   ANSIBLENS+=`oc get $i --all-namespaces --no-headers=true -o custom-columns=NAMESPACE:.metadata.namespace; echo " "`
done

NS=`echo ${ANSIBLENS[@]} | xargs -n1 | sort -u`

for a in $NS; do
  oc adm inspect ns/"$a"  --dest-dir=must-gather
  oc adm inspect -n $a csv --dest-dir=must-gather
  oc get pods -n $a >> ${BASE_COLLECTION_PATH}/gather-aap.log

  # Collect PVC status and common resources for each namespace
  echo "Collecting PVC status and common resources for namespace: $a"

  # PVC status with namespace header
  echo "" >> ${BASE_COLLECTION_PATH}/pvc-status.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/pvc-status.log
  echo "NAMESPACE: $a" >> ${BASE_COLLECTION_PATH}/pvc-status.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/pvc-status.log
  oc get pvc -n $a -o wide >> ${BASE_COLLECTION_PATH}/pvc-status.log 2>/dev/null || echo "No PVCs found in namespace $a" >> ${BASE_COLLECTION_PATH}/pvc-status.log

  # Deployments with namespace header
  echo "" >> ${BASE_COLLECTION_PATH}/deployments.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/deployments.log
  echo "NAMESPACE: $a" >> ${BASE_COLLECTION_PATH}/deployments.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/deployments.log
  oc get deployments -n $a -o wide >> ${BASE_COLLECTION_PATH}/deployments.log 2>/dev/null || echo "No deployments found in namespace $a" >> ${BASE_COLLECTION_PATH}/deployments.log

  # Services with namespace header
  echo "" >> ${BASE_COLLECTION_PATH}/services.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/services.log
  echo "NAMESPACE: $a" >> ${BASE_COLLECTION_PATH}/services.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/services.log
  oc get services -n $a -o wide >> ${BASE_COLLECTION_PATH}/services.log 2>/dev/null || echo "No services found in namespace $a" >> ${BASE_COLLECTION_PATH}/services.log

  # ConfigMaps with namespace header
  echo "" >> ${BASE_COLLECTION_PATH}/configmaps.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/configmaps.log
  echo "NAMESPACE: $a" >> ${BASE_COLLECTION_PATH}/configmaps.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/configmaps.log
  oc get configmaps -n $a -o wide >> ${BASE_COLLECTION_PATH}/configmaps.log 2>/dev/null || echo "No configmaps found in namespace $a" >> ${BASE_COLLECTION_PATH}/configmaps.log

  # Secrets with namespace header
  echo "" >> ${BASE_COLLECTION_PATH}/secrets.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/secrets.log
  echo "NAMESPACE: $a" >> ${BASE_COLLECTION_PATH}/secrets.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/secrets.log
  oc get secrets -n $a -o wide >> ${BASE_COLLECTION_PATH}/secrets.log 2>/dev/null || echo "No secrets found in namespace $a" >> ${BASE_COLLECTION_PATH}/secrets.log

  # Routes with namespace header
  echo "" >> ${BASE_COLLECTION_PATH}/routes.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/routes.log
  echo "NAMESPACE: $a" >> ${BASE_COLLECTION_PATH}/routes.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/routes.log
  oc get routes -n $a -o wide >> ${BASE_COLLECTION_PATH}/routes.log 2>/dev/null || echo "No routes found in namespace $a" >> ${BASE_COLLECTION_PATH}/routes.log

  # Ingress with namespace header
  echo "" >> ${BASE_COLLECTION_PATH}/ingress.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/ingress.log
  echo "NAMESPACE: $a" >> ${BASE_COLLECTION_PATH}/ingress.log
  echo "========================================" >> ${BASE_COLLECTION_PATH}/ingress.log
  oc get ingress -n $a -o wide >> ${BASE_COLLECTION_PATH}/ingress.log 2>/dev/null || echo "No ingress found in namespace $a" >> ${BASE_COLLECTION_PATH}/ingress.log
done

for b in $(oc get -A subs --field-selector='metadata.name=ansible-automation-platform-operator' -o custom-columns=NAMESPACE:.metadata.namespace); do
  oc adm inspect ns/"$b" --dest-dir=must-gather
  oc get pods -n $b >> ${BASE_COLLECTION_PATH}/gather-aap.log
  oc adm inspect -n $b subs --dest-dir=must-gather
done

# Function to collect initContainer logs
collect_init_container_logs() {
  local namespace=$1
  echo "Collecting initContainer logs for namespace: $namespace"

  # Get all pods in the namespace
  for pod in $(oc get pods -n $namespace -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    # Check if pod has initContainers
    init_containers=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.initContainers[*].name}' 2>/dev/null)
    if [ ! -z "$init_containers" ]; then
      echo "Found initContainers in pod $pod: $init_containers"
      for init_container in $init_containers; do
        echo "Collecting logs for initContainer: $init_container in pod: $pod"
        oc logs $pod -n $namespace -c $init_container > "${BASE_COLLECTION_PATH}/logs/${pod}-${init_container}-init.log" 2>/dev/null || echo "Failed to collect logs for initContainer $init_container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      done
    fi
  done
}

# Function to collect migration job logs
collect_migration_job_logs() {
  local namespace=$1
  echo "Collecting migration job logs for namespace: $namespace"

  # Collect logs from controller migration jobs
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=automationcontroller --field-selector=status.phase=Succeeded -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    # Check if this is a migration job pod
    if [[ "$pod" == *"migration"* ]]; then
      echo "Found controller migration job pod: $pod"
      # Get the container name for the migration job
      migration_container=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[0].name}' 2>/dev/null)
      if [ ! -z "$migration_container" ]; then
        echo "Collecting logs for migration job container: $migration_container in pod: $pod"
        oc logs $pod -n $namespace -c $migration_container > "${BASE_COLLECTION_PATH}/logs/${pod}-${migration_container}.log" 2>/dev/null || echo "Failed to collect logs for migration job $migration_container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      fi
    fi
  done

  # Also collect logs from any running or failed migration jobs
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=automationcontroller --field-selector=status.phase=Failed -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    if [[ "$pod" == *"migration"* ]]; then
      echo "Found failed controller migration job pod: $pod"
      migration_container=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[0].name}' 2>/dev/null)
      if [ ! -z "$migration_container" ]; then
        echo "Collecting logs for failed migration job container: $migration_container in pod: $pod"
        oc logs $pod -n $namespace -c $migration_container > "${BASE_COLLECTION_PATH}/logs/${pod}-${migration_container}.log" 2>/dev/null || echo "Failed to collect logs for failed migration job $migration_container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      fi
    fi
  done

  # Collect logs from gateway migration jobs
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/name=automation-platform-gateway --field-selector=status.phase=Succeeded -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    if [[ "$pod" == *"migration"* ]]; then
      echo "Found gateway migration job pod: $pod"
      migration_container=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[0].name}' 2>/dev/null)
      if [ ! -z "$migration_container" ]; then
        echo "Collecting logs for gateway migration job container: $migration_container in pod: $pod"
        oc logs $pod -n $namespace -c $migration_container > "${BASE_COLLECTION_PATH}/logs/${pod}-${migration_container}.log" 2>/dev/null || echo "Failed to collect logs for gateway migration job $migration_container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      fi
    fi
  done

  # Collect logs from EDA migration jobs
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=eda --field-selector=status.phase=Succeeded -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    if [[ "$pod" == *"migration"* ]]; then
      echo "Found EDA migration job pod: $pod"
      migration_container=$(oc get pod $pod -n $namespace -o jsonpath='{.spec.containers[0].name}' 2>/dev/null)
      if [ ! -z "$migration_container" ]; then
        echo "Collecting logs for EDA migration job container: $migration_container in pod: $pod"
        oc logs $pod -n $namespace -c $migration_container > "${BASE_COLLECTION_PATH}/logs/${pod}-${migration_container}.log" 2>/dev/null || echo "Failed to collect logs for EDA migration job $migration_container in pod $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
      fi
    fi
  done
}

# Function to collect showmigrations output
collect_showmigrations() {
  local namespace=$1
  echo "Collecting showmigrations output for namespace: $namespace"

  # Collect from automation controller task pods
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=task -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting showmigrations from controller task pod: $pod"
    oc exec $pod -n $namespace -c automation-controller-task -- awx-manage showmigrations > "${BASE_COLLECTION_PATH}/commands/${pod}-awx-task-showmigrations.log" 2>/dev/null || echo "Failed to collect showmigrations from task $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  done

  # Collect from automation controller web pods
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=automationcontroller -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    # Check if this is a web pod (not task pod)
    if [[ "$pod" == *"web"* ]]; then
      echo "Collecting showmigrations from controller web pod: $pod"
      oc exec $pod -n $namespace -c myaap-controller-web -- awx-manage showmigrations > "${BASE_COLLECTION_PATH}/commands/${pod}-awx-web-showmigrations.log" 2>/dev/null || echo "Failed to collect showmigrations from web $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
    fi
  done

  # Collect from gateway pods
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=aap-gateway -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting showmigrations from gateway pod: $pod"
    oc exec $pod -n $namespace -c api -- aap-gateway-manage showmigrations > "${BASE_COLLECTION_PATH}/commands/${pod}-gateway-showmigrations.log" 2>/dev/null || echo "Failed to collect showmigrations from gateway $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  done

  # Collect from automation hub API pods
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/name=automationhub-api -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting showmigrations from hub API pod: $pod"
    # Try multiple possible management commands for hub
    oc exec $pod -n $namespace -c api -- pulpcore-manage showmigrations > "${BASE_COLLECTION_PATH}/commands/${pod}-hub-showmigrations.log" 2>/dev/null || \
    oc exec $pod -n $namespace -c api -- python -m pulpcore.app.manage showmigrations > "${BASE_COLLECTION_PATH}/commands/${pod}-hub-showmigrations.log" 2>/dev/null || \
    echo "Failed to collect showmigrations from hub $pod - management command not available" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  done

  # Collect from EDA pods
  for pod in $(oc get pods -n $namespace -l app.kubernetes.io/component=eda-api -o jsonpath='{.items[*].metadata.name}' 2>/dev/null); do
    echo "Collecting showmigrations from EDA pod: $pod"
    oc exec $pod -n $namespace -c eda-api -- aap-eda-manage showmigrations > "${BASE_COLLECTION_PATH}/commands/${pod}-eda-showmigrations.log" 2>/dev/null || echo "Failed to collect showmigrations from EDA $pod" >> "${BASE_COLLECTION_PATH}/gather-aap.log"
  done
}

# Call functions for each AAP namespace
echo "Found AAP namespaces: $NS"
if [ ! -z "$NS" ]; then
  for a in $NS; do
    echo "Processing namespace: $a"
    collect_init_container_logs $a || echo "Failed to collect init container logs for $a"
    collect_migration_job_logs $a || echo "Failed to collect migration job logs for $a"
    collect_showmigrations $a || echo "Failed to collect showmigrations for $a"
  done
else
  echo "No AAP namespaces found, skipping custom collection functions"
fi

echo "WARNING: Collecting kernel messages on ALL nodes in your cluster. This could take a large amount of time."
oc adm node-logs --role=master -l kubernetes.io/os=linux --grep kernel > "${BASE_COLLECTION_PATH}/master_dmesg.log"
oc adm node-logs --role=worker -l kubernetes.io/os=linux --grep kernel > "${BASE_COLLECTION_PATH}/worker_dmesg.log"

# Function to analyze errors and generate summary report
generate_summary_report() {
  echo "Generating summary report..."

  SUMMARY_FILE="${BASE_COLLECTION_PATH}/reports/summary-report.html"
  ERROR_SUMMARY="${BASE_COLLECTION_PATH}/reports/error-summary.log"

  # Create HTML header
  cat > $SUMMARY_FILE << EOF
<!DOCTYPE html>
<html>
<head>
    <title>AAP Must-Gather Summary Report</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        .section { margin: 20px 0; padding: 15px; border: 1px solid #ddd; }
        .error { color: red; }
        .warning { color: orange; }
        .info { color: blue; }
        table { border-collapse: collapse; width: 100%; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        th { background-color: #f2f2f2; }
        pre { background-color: #f5f5f5; padding: 10px; overflow-x: auto; }
    </style>
</head>
<body>
    <h1>AAP Must-Gather Summary Report</h1>
    <p>Generated on: $(date)</p>
EOF

  # Collect version information
  echo "    <div class='section'>" >> $SUMMARY_FILE
  echo "        <h2>Version Information</h2>" >> $SUMMARY_FILE

  # Get cluster version
  CLUSTER_VERSION=$(oc get clusterversion version -o jsonpath='{.status.desired.version}' 2>/dev/null || echo "Unknown")
  echo "        <p><strong>OpenShift Version:</strong> $CLUSTER_VERSION</p>" >> $SUMMARY_FILE

  # Get AAP operator version
  AAP_VERSION=$(oc get csv -A -o jsonpath='{.items[?(@.spec.displayName=="Ansible Automation Platform")].spec.version}' 2>/dev/null | head -1 || echo "Unknown")
  echo "        <p><strong>AAP Operator Version:</strong> $AAP_VERSION</p>" >> $SUMMARY_FILE

  # Get upgrade status
  UPGRADE_FROM=$(oc get clusterversion version -o jsonpath='{.status.history[1].version}' 2>/dev/null || echo "N/A")
  echo "        <p><strong>Upgraded From:</strong> $UPGRADE_FROM</p>" >> $SUMMARY_FILE

  echo "    </div>" >> $SUMMARY_FILE

  # Add AAP Custom Resources table
  echo "    <div class='section'>" >> $SUMMARY_FILE
  echo "        <h2>AAP Custom Resources</h2>" >> $SUMMARY_FILE
  echo "        <style>" >> $SUMMARY_FILE
  echo "            .namespace-separator { border-top: 3px solid #333; background-color: #f8f9fa; font-weight: bold; }" >> $SUMMARY_FILE
  echo "        </style>" >> $SUMMARY_FILE
  echo "        <table>" >> $SUMMARY_FILE
  echo "            <tr><th>Type</th><th>Name</th><th>Namespace</th><th>Version</th><th>Status</th></tr>" >> $SUMMARY_FILE

  # Create a temporary file to collect all CR data
  TEMP_CR_DATA=$(mktemp)

  # Function to extract CR information and store in temp file
  extract_cr_info() {
    local cr_type="$1"
    local cr_kind="$2"
    local icon="$3"
    local api_group="$4"

    find ${BASE_COLLECTION_PATH}/namespaces -name "${cr_type}" -type d 2>/dev/null | while read cr_dir; do
      find "$cr_dir" -name "*.yaml" -type f | sort | while read cr_file; do
        local name=$(grep "^  name:" "$cr_file" | head -1 | awk '{print $2}')
        local namespace=$(echo "$cr_dir" | sed 's|.*/namespaces/||' | sed 's|/.*||')
        local version="N/A"
        local status_display="Unknown"

        # Extract version based on CR type
        if [ "$cr_kind" = "AutomationHub" ]; then
          # For AutomationHub, look for deployedVersion
          version=$(grep "^  deployedVersion:" "$cr_file" | head -1 | awk '{print $2}' || echo "N/A")
        else
          # For other CRs, look for version in status
          version=$(grep "^  version:" "$cr_file" | head -1 | awk '{print $2}' || echo "N/A")
        fi

        # If version not found in status, try to get it from image field
        if [ "$version" = "N/A" ]; then
          version=$(grep "^  image:" "$cr_file" | head -1 | sed -n 's/.*:\([^:]*\)$/\1/p' || echo "N/A")
        fi

        # Extract status information with specific handling per CR type
        if grep -q "^status:" "$cr_file"; then
          case "$cr_kind" in
            "AutomationHub")
              # Look for Automationhub-Operator-Finished-Execution specifically
              local hub_status=$(awk '
                /type: Automationhub-Operator-Finished-Execution/ {
                  # Found the type, now look backwards for status in the same condition block
                  for (i = NR-1; i >= NR-5; i--) {
                    if (i > 0 && lines[i] ~ /status:/) {
                      gsub(/"/, "", lines[i])
                      split(lines[i], parts, " ")
                      print parts[2]
                      break
                    }
                  }
                }
                { lines[NR] = $0 }
              ' "$cr_file")
              local hub_reason=$(awk '
                /type: Automationhub-Operator-Finished-Execution/ {
                  # Found the type, now look backwards for reason in the same condition block
                  for (i = NR-1; i >= NR-5; i--) {
                    if (i > 0 && lines[i] ~ /reason:/) {
                      gsub(/"/, "", lines[i])
                      split(lines[i], parts, " ")
                      print parts[2]
                      break
                    }
                  }
                }
                { lines[NR] = $0 }
              ' "$cr_file")
              if [ "$hub_status" = "True" ] && [ "$hub_reason" = "OperatorFinishedExecution" ]; then
                status_display="Ready (OperatorFinishedExecution)"
              elif [ "$hub_status" = "True" ]; then
                status_display="Ready ($hub_reason)"
              elif [ "$hub_status" = "False" ]; then
                status_display="Not Ready ($hub_reason)"
              else
                status_display="Unknown"
              fi
              ;;
            *)
              # For other CRs, look for standard conditions with reasons
              local running_status=$(awk '/type: Running/{found=1} found && /status:/{print $2; exit}' "$cr_file" | tr -d '"')
              local running_reason=$(awk '/type: Running/{found=1} found && /reason:/{print $2; exit}' "$cr_file" | tr -d '"')
              local successful_status=$(awk '/type: Successful/{found=1} found && /status:/{print $2; exit}' "$cr_file" | tr -d '"')
              local successful_reason=$(awk '/type: Successful/{found=1} found && /reason:/{print $2; exit}' "$cr_file" | tr -d '"')
              local failure_status=$(awk '/type: Failure/{found=1} found && /status:/{print $2; exit}' "$cr_file" | tr -d '"')
              local failure_reason=$(awk '/type: Failure/{found=1} found && /reason:/{print $2; exit}' "$cr_file" | tr -d '"')

              if [ "$running_status" = "True" ]; then
                status_display="Running ($running_reason)"
              elif [ "$successful_status" = "True" ]; then
                status_display="Successful ($successful_reason)"
              elif [ "$failure_status" = "True" ]; then
                status_display="Failed ($failure_reason)"
              elif [ "$running_status" = "False" ] || [ "$successful_status" = "False" ]; then
                local reason="$running_reason"
                [ -n "$successful_reason" ] && reason="$successful_reason"
                status_display="Not Ready ($reason)"
              fi
              ;;
          esac
        fi

        # Store data in format: namespace|icon|cr_kind|name|version|status_display
        echo "$namespace|$icon|$cr_kind|$name|$version|$status_display" >> $TEMP_CR_DATA
      done
    done
  }

  # Extract information for each CR type
  extract_cr_info "ansibleautomationplatforms" "AAP" "🏢" "aap.ansible.com"
  extract_cr_info "automationcontrollers" "AutomationController" "🎮" "automationcontroller.ansible.com"
  extract_cr_info "automationhubs" "AutomationHub" "📦" "automationhub.ansible.com"
  extract_cr_info "edas" "EDA" "⚡" "eda.ansible.com"
  extract_cr_info "ansiblelightspeeds" "AnsibleLightspeed" "💡" "lightspeed.ansible.com"

  # Sort by namespace and generate grouped table
  if [ -f "$TEMP_CR_DATA" ] && [ -s "$TEMP_CR_DATA" ]; then
    local prev_namespace=""
    sort "$TEMP_CR_DATA" | while IFS='|' read namespace icon cr_kind name version status_display; do
      # Add namespace separator if this is a new namespace
      if [ "$namespace" != "$prev_namespace" ]; then
        if [ -n "$prev_namespace" ]; then
          # Add a separator row between namespaces
          echo "            <tr class='namespace-separator'><td colspan='5' style='text-align: center; padding: 8px;'>───────────────────────────────────────────────────────────────</td></tr>" >> $SUMMARY_FILE
        fi
        prev_namespace="$namespace"
      fi
      echo "            <tr><td>$icon $cr_kind</td><td>$name</td><td>$namespace</td><td>$version</td><td>$status_display</td></tr>" >> $SUMMARY_FILE
    done
  else
    echo "            <tr><td colspan='5' style='text-align: center; font-style: italic;'>No AAP Custom Resources found in the collected data.</td></tr>" >> $SUMMARY_FILE
  fi

  # Clean up temporary file
  rm -f "$TEMP_CR_DATA"

  echo "        </table>" >> $SUMMARY_FILE
  echo "        <p><em>Custom Resource instances grouped by namespace with their current version and status information.</em></p>" >> $SUMMARY_FILE
  echo "    </div>" >> $SUMMARY_FILE

  # Analyze errors in log files
  echo "    <div class='section'>" >> $SUMMARY_FILE
  echo "        <h2>Error Analysis</h2>" >> $SUMMARY_FILE
  echo "        <p>Searching for errors in collected logs...</p>" >> $SUMMARY_FILE

  # Search for errors in all log files (excluding migration-related false positives)
  > $ERROR_SUMMARY
  find ${BASE_COLLECTION_PATH} -name "*.log" -type f | while read logfile; do
    echo "Analyzing: $logfile" >> $ERROR_SUMMARY
    grep -i -n -E "(error|exception|failed|fatal|panic|traceback)" "$logfile" 2>/dev/null | \
      grep -v -E "(0007_alter_validators_add_error_messages|0009_remove_task_non_fatal_errors|0010_servicecluster_healthy_panic_threshold_and_more)" | \
      head -20 >> $ERROR_SUMMARY || true
    echo "---" >> $ERROR_SUMMARY
  done

  # Add error summary to HTML
  echo "        <h3>Error Summary</h3>" >> $SUMMARY_FILE
  echo "        <pre>" >> $SUMMARY_FILE
  head -100 $ERROR_SUMMARY >> $SUMMARY_FILE 2>/dev/null || echo "No errors found or error file not accessible" >> $SUMMARY_FILE
  echo "        </pre>" >> $SUMMARY_FILE
  echo "        <p><em>Full error analysis available in: reports/error-summary.log</em></p>" >> $SUMMARY_FILE
  echo "    </div>" >> $SUMMARY_FILE

  # Close HTML
